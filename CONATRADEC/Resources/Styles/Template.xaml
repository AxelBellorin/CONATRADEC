<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:CONATRADEC.Controls">

    <!--
        Menú principal compartido:
        - Windows: barra lateral.
        - Android/iOS: barra inferior.

        Las cuatro opciones principales usan AppNavigationMenuItem para:
        - no depender del IsBusy de la pantalla actual;
        - evitar navegaciones duplicadas;
        - marcar automáticamente la opción activa;
        - mantener inmóvil el menú durante la navegación;
        - animar únicamente el contenido de la derecha.
    -->
    <ControlTemplate x:Key="FooterTemplate">

        <Grid
            RowDefinitions="*,Auto"
            ColumnDefinitions="{OnPlatform WinUI='230,*', Default='*'}"
            BackgroundColor="{StaticResource color_Blanco}">

            <!-- ===================================================== -->
            <!-- NAVEGACIÓN DE WINDOWS                                 -->
            <!-- ===================================================== -->
            <Border
                Grid.Row="0"
                Grid.RowSpan="2"
                Grid.Column="0"
                IsVisible="{OnPlatform WinUI=True, Default=False}"
                Padding="14,18"
                BackgroundColor="White"
                Stroke="#E5E7EB"
                StrokeThickness="1">

                <Border.Shadow>
                    <Shadow
                        Brush="Black"
                        Offset="3,0"
                        Radius="12"
                        Opacity="0.08" />
                </Border.Shadow>

                <Grid RowDefinitions="Auto,*,Auto">

                    <!-- Identidad de la aplicación -->
                    <VerticalStackLayout
                        Grid.Row="0"
                        Padding="10,8,10,20"
                        Spacing="3">

                        <Label
                            Text="ConatraCafé"
                            FontSize="22"
                            FontFamily="MontserratBold"
                            FontAttributes="Bold"
                            TextColor="{StaticResource color_Verde}" />

                        <Label
                            Text="Soil"
                            FontSize="13"
                            FontFamily="MontserratMedium"
                            TextColor="{StaticResource color_GrisOscuro}" />

                    </VerticalStackLayout>

                    <!-- Opciones principales -->
                    <VerticalStackLayout
                        Grid.Row="1"
                        Spacing="8">

                        <controls:AppNavigationMenuItem
                            Texto="Inicio"
                            Icono="iconhome.png"
                            Interfaz="MainPage"
                            Ruta="//MainPage"
                            Seccion="Inicio" />

                        <controls:AppNavigationMenuItem
                            Texto="Álbum de fotos"
                            Icono="iconalbum.png"
                            Interfaz="albumFotosPage"
                            Ruta="albumFotosPage"
                            Seccion="Album" />

                        <controls:AppNavigationMenuItem
                            Texto="Noticias"
                            Icono="iconnews.png"
                            Interfaz="noticiasPage"
                            Ruta="//noticiasPage"
                            Seccion="Noticias" />

                        <controls:AppNavigationMenuItem
                            Texto="Configuración"
                            Icono="iconsettings.png"
                            Ruta="//ConfiguracionPage"
                            Seccion="Configuracion" />

                    </VerticalStackLayout>

                    <!-- Cerrar sesión -->
                    <VerticalStackLayout
                        Grid.Row="2"
                        Spacing="10">

                        <BoxView
                            HeightRequest="1"
                            Color="#E5E7EB"
                            Margin="0,0,0,4" />

                        <Border
                            Padding="14,11"
                            BackgroundColor="#FEF2F2"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 12">

                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding CerrarSesionCommand}" />
                            </Border.GestureRecognizers>

                            <Grid
                                ColumnDefinitions="26,*"
                                ColumnSpacing="12">

                                <Image
                                    Source="iconloginout.png"
                                    HeightRequest="24"
                                    WidthRequest="24"
                                    VerticalOptions="Center" />

                                <Label
                                    Grid.Column="1"
                                    Text="Cerrar sesión"
                                    FontFamily="MontserratMedium"
                                    FontSize="15"
                                    TextColor="{StaticResource RedDelete}"
                                    VerticalOptions="Center" />
                            </Grid>
                        </Border>

                    </VerticalStackLayout>

                </Grid>
            </Border>

            <!-- Contenido compartido por ambas plataformas -->
            <ContentPresenter
                Grid.Row="0"
                Grid.Column="{OnPlatform WinUI=1, Default=0}"
                BackgroundColor="{StaticResource color_Blanco}">

                <ContentPresenter.Behaviors>
                    <controls:NavigationContentTransitionBehavior />
                </ContentPresenter.Behaviors>
            </ContentPresenter>

            <!-- ===================================================== -->
            <!-- NAVEGACIÓN DE MÓVIL                                  -->
            <!-- ===================================================== -->
            <Border
                Grid.Row="1"
                Grid.Column="0"
                IsVisible="{OnPlatform WinUI=False, Default=True}"
                Padding="5,8,5,10"
                BackgroundColor="{StaticResource color_Blanco}"
                Stroke="#E5E7EB"
                StrokeThickness="1">

                <Border.Shadow>
                    <Shadow
                        Brush="Black"
                        Offset="0,-3"
                        Radius="12"
                        Opacity="0.10" />
                </Border.Shadow>

                <Grid
                    ColumnDefinitions="*,*,*,*,*"
                    ColumnSpacing="1">

                    <controls:AppNavigationMenuItem
                        Grid.Column="0"
                        Texto="Inicio"
                        Icono="iconhome.png"
                        Interfaz="MainPage"
                        Ruta="//MainPage"
                        Seccion="Inicio"
                        EsMovil="True" />

                    <controls:AppNavigationMenuItem
                        Grid.Column="1"
                        Texto="Álbum"
                        Icono="iconalbum.png"
                        Interfaz="albumFotosPage"
                        Ruta="albumFotosPage"
                        Seccion="Album"
                        EsMovil="True" />

                    <controls:AppNavigationMenuItem
                        Grid.Column="2"
                        Texto="Noticias"
                        Icono="iconnews.png"
                        Interfaz="noticiasPage"
                        Ruta="//noticiasPage"
                        Seccion="Noticias"
                        EsMovil="True" />

                    <controls:AppNavigationMenuItem
                        Grid.Column="3"
                        Texto="Config."
                        Icono="iconsettings.png"
                        Ruta="//ConfiguracionPage"
                        Seccion="Configuracion"
                        EsMovil="True" />

                    <!-- Salir -->
                    <VerticalStackLayout
                        Grid.Column="4"
                        Padding="2,5"
                        Spacing="4"
                        BackgroundColor="Transparent"
                        HorizontalOptions="Fill">

                        <VerticalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding CerrarSesionCommand}" />
                        </VerticalStackLayout.GestureRecognizers>

                        <Image
                            Source="iconloginout.png"
                            HeightRequest="25"
                            WidthRequest="25"
                            HorizontalOptions="Center" />

                        <Label
                            Text="Salir"
                            FontSize="10"
                            FontFamily="MontserratMedium"
                            TextColor="{StaticResource RedDelete}"
                            HorizontalTextAlignment="Center"
                            HorizontalOptions="Fill" />

                    </VerticalStackLayout>

                </Grid>
            </Border>

        </Grid>
    </ControlTemplate>
</ResourceDictionary>
