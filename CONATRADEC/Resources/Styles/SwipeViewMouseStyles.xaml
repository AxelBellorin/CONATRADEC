<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:behaviors="clr-namespace:CONATRADEC.Behaviors">

    <!--
        Se aplica globalmente a todos los SwipeView.
        El comportamiento solamente conecta el evento nativo en Windows;
        Android y las demás plataformas conservan su funcionamiento táctil.
    -->
    <Style TargetType="SwipeView">
        <Setter
            Property="behaviors:SwipeViewRightClick.IsEnabled"
            Value="True" />
    </Style>

</ResourceDictionary>
