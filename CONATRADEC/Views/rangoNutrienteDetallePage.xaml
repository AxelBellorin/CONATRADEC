<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="CONATRADEC.Views.rangoNutrienteDetallePage"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{OnPlatform WinUI='Transparent', Default={StaticResource color_Blanco}}">

    <ContentView
        x:Name="RootPage"
        ControlTemplate="{StaticResource FooterTemplate}">

        <Grid RowDefinitions="Auto,Auto,Auto,*">

            <Grid
                Grid.Row="0"
                ColumnDefinitions="Auto,*,Auto"
                Padding="8,10,8,2">

                <Button
                    Grid.Column="0"
                    Text="‹"
                    FontSize="28"
                    WidthRequest="48"
                    HeightRequest="48"
                    Padding="0"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource color_Verde}"
                    Command="{Binding BackCommand}"
                    IsEnabled="{Binding NotIsBusy}" />

                <Label
                    Grid.Column="1"
                    Text="{Binding Titulo}"
                    FontSize="23"
                    FontFamily="MontserratBold"
                    TextColor="{StaticResource color_Negro}"
                    VerticalOptions="Center"
                    LineBreakMode="TailTruncation"
                    MaxLines="2" />

                <ImageButton
                    Grid.Column="2"
                    Source="iconadd.png"
                    WidthRequest="54"
                    HeightRequest="54"
                    Command="{Binding AddCommand}"
                    IsVisible="{Binding CanAdd}"
                    IsEnabled="{Binding NotIsBusy}"
                    BackgroundColor="Transparent"
                    SemanticProperties.Description="Agregar rango de aporte" />

            </Grid>

            <VerticalStackLayout
                Grid.Row="1"
                Padding="20,0,20,8"
                Spacing="3">

                <Label
                    Text="{Binding ResumenAportes}"
                    FontSize="13"
                    FontFamily="MontserratMedium"
                    TextColor="{StaticResource color_Verde}" />

                <Label
                    Text="{Binding DescripcionCategoria}"
                    FontSize="12"
                    TextColor="{StaticResource color_Gris}"
                    LineBreakMode="TailTruncation"
                    MaxLines="2" />

            </VerticalStackLayout>

            <ActivityIndicator
                Grid.Row="2"
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}"
                Color="{StaticResource color_Naranja}" />

            <CollectionView
                Grid.Row="3"
                ItemsSource="{Binding Aportes}"
                SelectionMode="None">

                <CollectionView.EmptyView>
                    <Grid Padding="24">
                        <VerticalStackLayout
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            Spacing="8">

                            <Label
                                Text="Este tipo de cultivo todavía no tiene rangos de aporte."
                                HorizontalTextAlignment="Center" />

                            <Label
                                Text="Presione + para agregar el primero."
                                FontSize="12"
                                TextColor="{StaticResource color_Gris}"
                                HorizontalTextAlignment="Center" />

                        </VerticalStackLayout>
                    </Grid>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate>

                        <SwipeView
                            IsEnabled="{Binding Source={x:Reference RootPage}, Path=BindingContext.CanView}">

                            <SwipeView.RightItems>
                                <SwipeItems Mode="Reveal">

                                    <SwipeItem
                                        Text="Editar"
                                        IconImageSource="iconupdate.png"
                                        BackgroundColor="{StaticResource BlueUpdate}"
                                        Command="{Binding Source={x:Reference RootPage}, Path=BindingContext.EditCommand}"
                                        CommandParameter="{Binding .}"
                                        IsVisible="{Binding Source={x:Reference RootPage}, Path=BindingContext.CanEdit}" />

                                    <SwipeItem
                                        Text="Eliminar"
                                        IconImageSource="icondelete.png"
                                        BackgroundColor="{StaticResource RedDelete}"
                                        Command="{Binding Source={x:Reference RootPage}, Path=BindingContext.DeleteCommand}"
                                        CommandParameter="{Binding .}"
                                        IsVisible="{Binding Source={x:Reference RootPage}, Path=BindingContext.CanDelete}" />

                                </SwipeItems>
                            </SwipeView.RightItems>

                            <Border
                                Margin="12,5"
                                Style="{OnPlatform WinUI={StaticResource BorderStyleNoCornerRadius}, Default={StaticResource BorderStyle}}">

                                <Grid Padding="14">

                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={x:Reference RootPage}, Path=BindingContext.ViewCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Grid.GestureRecognizers>

                                    <VerticalStackLayout Spacing="5">

                                        <Label
                                            Text="{Binding ElementoTexto}"
                                            FontSize="18"
                                            FontFamily="MontserratBold"
                                            TextColor="{StaticResource color_Verde}" />

                                        <Label
                                            Text="{Binding RangoTexto}"
                                            FontSize="14"
                                            FontFamily="MontserratMedium"
                                            TextColor="{StaticResource color_Negro}" />

                                        <Label
                                            Text="{Binding DescripcionParametro}"
                                            FontSize="12"
                                            TextColor="{StaticResource color_Gris}"
                                            LineBreakMode="TailTruncation"
                                            MaxLines="2" />

                                    </VerticalStackLayout>

                                </Grid>

                            </Border>

                        </SwipeView>

                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>

        </Grid>

    </ContentView>

</ContentPage>
