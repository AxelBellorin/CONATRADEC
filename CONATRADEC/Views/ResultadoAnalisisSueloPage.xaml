<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CONATRADEC.Views.ResultadoAnalisisSueloPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Resultado del análisis"
    BackgroundColor="#FFF5FF">

    <ScrollView>
        <VerticalStackLayout Padding="18" Spacing="16">

            <!-- Encabezado -->
            <Border
                BackgroundColor="#3B655B"
                StrokeThickness="0"
                Padding="18"
                StrokeShape="RoundRectangle 18">

                <VerticalStackLayout Spacing="6">
                    <Label
                        Text="{Binding TituloResultado}"
                        TextColor="White"
                        FontSize="22"
                        FontAttributes="Bold" />

                    <Label
                        Text="Resultado generado desde el cálculo preliminar del análisis de suelo."
                        TextColor="White"
                        FontSize="14"
                        Opacity="0.9"
                        LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>

            <!-- Recomendación general -->
            <Border
                BackgroundColor="White"
                Stroke="#E5E7EB"
                Padding="16"
                StrokeShape="RoundRectangle 16">

                <VerticalStackLayout Spacing="10">

                    <Label
                        Text="Recomendación general"
                        FontSize="18"
                        FontAttributes="Bold"
                        TextColor="#3B655B" />

                    <Label
                        Text="{Binding RecomendacionGeneral}"
                        FontSize="14"
                        TextColor="#333333"
                        LineBreakMode="WordWrap" />

                    <Border
                        BackgroundColor="#F0FDF4"
                        Stroke="#BBF7D0"
                        Padding="12"
                        StrokeShape="RoundRectangle 12">

                        <Label
                            Text="{Binding SugerenciaSiguienteCalculo}"
                            FontSize="14"
                            TextColor="#14532D"
                            LineBreakMode="WordWrap" />
                    </Border>

                    <VerticalStackLayout IsVisible="{Binding TieneObservaciones}" Spacing="8">

                        <Label
                            Text="Observaciones"
                            FontSize="16"
                            FontAttributes="Bold"
                            TextColor="#9B552C" />

                        <VerticalStackLayout
                            Spacing="0"
                            BindableLayout.ItemsSource="{Binding Observaciones}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        BackgroundColor="#FFF7ED"
                                        Stroke="#FED7AA"
                                        Padding="10"
                                        Margin="0,4"
                                        StrokeShape="RoundRectangle 10">

                                        <Label
                                            Text="{Binding .}"
                                            TextColor="#7C2D12"
                                            FontSize="14"
                                            LineBreakMode="WordWrap" />
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Border>

            <!-- Datos base -->
            <Border
                BackgroundColor="White"
                Stroke="#E5E7EB"
                Padding="16"
                StrokeShape="RoundRectangle 16">

                <VerticalStackLayout Spacing="12">

                    <Label
                        Text="Datos base del cálculo"
                        FontSize="18"
                        FontAttributes="Bold"
                        TextColor="#3B655B" />

                    <Grid
                        ColumnDefinitions="*,*"
                        RowDefinitions="Auto,Auto,Auto"
                        RowSpacing="10"
                        ColumnSpacing="12">

                        <VerticalStackLayout Grid.Row="0" Grid.Column="0">
                            <Label Text="Tipo de cultivo" FontSize="12" TextColor="#6B7280" />
                            <Label Text="{Binding TipoCultivo}" FontSize="15" FontAttributes="Bold" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Row="0" Grid.Column="1">
                            <Label Text="Tipo de análisis" FontSize="12" TextColor="#6B7280" />
                            <Label Text="{Binding TipoAnalisisSuelo}" FontSize="15" FontAttributes="Bold" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Row="1" Grid.Column="0">
                            <Label Text="QQ oro" FontSize="12" TextColor="#6B7280" />
                            <Label Text="{Binding CantidadQuintalesOro, StringFormat='{0:N2}'}" FontSize="15" FontAttributes="Bold" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Row="1" Grid.Column="1">
                            <Label Text="Tamaño finca" FontSize="12" TextColor="#6B7280" />
                            <Label Text="{Binding TamanoFinca, StringFormat='{0:N2} mz'}" FontSize="15" FontAttributes="Bold" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Row="2" Grid.Column="0">
                            <Label Text="pH" FontSize="12" TextColor="#6B7280" />
                            <Label Text="{Binding Ph, StringFormat='{0:N2}'}" FontSize="15" FontAttributes="Bold" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Row="2" Grid.Column="1">
                            <Label Text="Acidez total" FontSize="12" TextColor="#6B7280" />
                            <Label Text="{Binding AcidezTotal, StringFormat='{0:N2}'}" FontSize="15" FontAttributes="Bold" />
                        </VerticalStackLayout>

                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- Requerimientos por elemento -->
            <Label
                Text="Requerimientos por elemento"
                FontSize="19"
                FontAttributes="Bold"
                TextColor="#3B655B"
                Margin="0,4,0,0"
                IsVisible="{Binding TieneElementos}" />

            <VerticalStackLayout
                Spacing="0"
                BindableLayout.ItemsSource="{Binding Elementos}"
                IsVisible="{Binding TieneElementos}">

                <BindableLayout.ItemTemplate>
                    <DataTemplate>

                        <Border
                            BackgroundColor="White"
                            Stroke="#E5E7EB"
                            Padding="14"
                            Margin="0,0,0,12"
                            StrokeShape="RoundRectangle 16">

                            <VerticalStackLayout Spacing="10">

                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">

                                    <Border
                                        Grid.Column="0"
                                        WidthRequest="48"
                                        HeightRequest="48"
                                        BackgroundColor="#3B655B"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 24">

                                        <Label
                                            Text="{Binding SimboloElementoQuimico}"
                                            TextColor="White"
                                            FontAttributes="Bold"
                                            FontSize="18"
                                            HorizontalOptions="Center"
                                            VerticalOptions="Center" />
                                    </Border>

                                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                                        <Label
                                            Text="{Binding NombreElementoQuimico}"
                                            FontSize="16"
                                            FontAttributes="Bold"
                                            TextColor="#111827" />

                                        <Label
                                            Text="{Binding SimboloElementoQuimico}"
                                            FontSize="13"
                                            TextColor="#6B7280" />
                                    </VerticalStackLayout>

                                    <Label
                                        Grid.Column="2"
                                        Text="{Binding Clasificacion}"
                                        FontSize="11"
                                        FontAttributes="Bold"
                                        Padding="8,4"
                                        TextColor="White"
                                        BackgroundColor="#6B7280"
                                        VerticalOptions="Center">

                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding Clasificacion}" Value="MUY_BAJO">
                                                <Setter Property="BackgroundColor" Value="#DC2626" />
                                            </DataTrigger>

                                            <DataTrigger TargetType="Label" Binding="{Binding Clasificacion}" Value="MEDIO_BAJO">
                                                <Setter Property="BackgroundColor" Value="#F59E0B" />
                                            </DataTrigger>

                                            <DataTrigger TargetType="Label" Binding="{Binding Clasificacion}" Value="EXCESIVO">
                                                <Setter Property="BackgroundColor" Value="#7C3AED" />
                                            </DataTrigger>

                                            <DataTrigger TargetType="Label" Binding="{Binding Clasificacion}" Value="ADECUADO">
                                                <Setter Property="BackgroundColor" Value="#16A34A" />
                                            </DataTrigger>
                                        </Label.Triggers>

                                    </Label>

                                </Grid>

                                <Grid
                                    ColumnDefinitions="*,*"
                                    RowDefinitions="Auto,Auto,Auto"
                                    RowSpacing="8"
                                    ColumnSpacing="12">

                                    <VerticalStackLayout Grid.Row="0" Grid.Column="0">
                                        <Label Text="Cantidad en el suelo" FontSize="12" TextColor="#6B7280" />
                                        <Label Text="{Binding CantidadConvertidaLbMz, StringFormat='{0:N2} lb/mz'}" FontSize="14" FontAttributes="Bold" />
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Grid.Row="0" Grid.Column="1">
                                        <Label Text="Requerimiento" FontSize="12" TextColor="#6B7280" />
                                        <Label Text="{Binding RequerimientoCalculado, StringFormat='{0:N2} lb/mz'}" FontSize="14" FontAttributes="Bold" />
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Grid.Row="1" Grid.Column="0">
                                        <Label Text="Rango mínimo" FontSize="12" TextColor="#6B7280" />
                                        <Label Text="{Binding RangoMinimoLbMz, StringFormat='{0:N2} lb/mz'}" FontSize="14" />
                                    </VerticalStackLayout>
 
                                    <VerticalStackLayout Grid.Row="1" Grid.Column="1">
                                        <Label Text="Rango máximo" FontSize="12" TextColor="#6B7280" />
                                        <Label Text="{Binding RangoMaximoLbMz, StringFormat='{0:N2} lb/mz'}" FontSize="14" />
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Grid.Row="2" Grid.Column="0">
                                        <Label Text="Extracción por QQ" FontSize="12" TextColor="#6B7280" />
                                        <Label Text="{Binding ExtraccionPorQQOro, StringFormat='{0:N2}'}" FontSize="14" />
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Grid.Row="2" Grid.Column="1">
                                        <Label Text="Extracción producción" FontSize="12" TextColor="#6B7280" />
                                        <Label Text="{Binding ExtraccionPorProduccion, StringFormat='{0:N2}'}" FontSize="14" />
                                    </VerticalStackLayout>

                                </Grid>

                                <Label
                                    Text="{Binding Observacion}"
                                    FontSize="13"
                                    TextColor="#374151"
                                    LineBreakMode="WordWrap" />

                            </VerticalStackLayout>

                        </Border>

                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <!-- Selección de cálculos opcionales -->
            <Border
                BackgroundColor="White"
                Stroke="#E5E7EB"
                Padding="16"
                StrokeShape="RoundRectangle 16">

                <VerticalStackLayout Spacing="14">

                    <VerticalStackLayout Spacing="4">
                        <Label
                            Text="Cálculos opcionales"
                            FontSize="18"
                            FontAttributes="Bold"
                            TextColor="#3B655B" />

                        <Label
                            Text="Seleccione uno o varios cálculos que desea procesar. Estos cálculos no son obligatorios."
                            FontSize="14"
                            TextColor="#6B7280"
                            LineBreakMode="WordWrap" />
                    </VerticalStackLayout>

                    <!-- Balance de fórmula -->
                    <Border
                        BackgroundColor="#F9FAFB"
                        Stroke="#E5E7EB"
                        Padding="12"
                        StrokeShape="RoundRectangle 14">

                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">

                            <CheckBox
                                Grid.Column="0"
                                Color="#3B655B"
                                IsChecked="{Binding CalcularBalanceFormula}"
                                VerticalOptions="Center" />

                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label
                                    Text="Balance de fórmula"
                                    FontSize="15"
                                    FontAttributes="Bold"
                                    TextColor="#111827" />

                                <Label
                                    Text="Permite calcular la fórmula de fertilización según los requerimientos detectados."
                                    FontSize="13"
                                    TextColor="#6B7280"
                                    LineBreakMode="WordWrap" />
                            </VerticalStackLayout>

                        </Grid>
                    </Border>

                    <!-- Enmienda calcárea -->
                    <Border
                        BackgroundColor="#F9FAFB"
                        Stroke="#E5E7EB"
                        Padding="12"
                        StrokeShape="RoundRectangle 14">

                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">

                            <CheckBox
                                Grid.Column="0"
                                Color="#9B552C"
                                IsChecked="{Binding CalcularEnmiendaCalcarea}"
                                VerticalOptions="Center" />

                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label
                                    Text="Enmienda calcárea"
                                    FontSize="15"
                                    FontAttributes="Bold"
                                    TextColor="#111827" />

                                <Label
                                    Text="Recomendado cuando el pH o la acidez indican necesidad de corrección del suelo."
                                    FontSize="13"
                                    TextColor="#6B7280"
                                    LineBreakMode="WordWrap" />
                            </VerticalStackLayout>

                        </Grid>
                    </Border>

                    <!-- Fertilización mixta -->
                    <Border
                        BackgroundColor="#F9FAFB"
                        Stroke="#E5E7EB"
                        Padding="12"
                        StrokeShape="RoundRectangle 14">

                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">

                            <CheckBox
                                Grid.Column="0"
                                Color="#F2C94C"
                                IsChecked="{Binding CalcularFertilizacionMixta}"
                                VerticalOptions="Center" />

                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label
                                    Text="Fertilización mixta"
                                    FontSize="15"
                                    FontAttributes="Bold"
                                    TextColor="#111827" />

                                <Label
                                    Text="Permite combinar diferentes criterios de fertilización según el análisis obtenido."
                                    FontSize="13"
                                    TextColor="#6B7280"
                                    LineBreakMode="WordWrap" />
                            </VerticalStackLayout>

                        </Grid>
                    </Border>

                    <Border
                        IsVisible="{Binding TieneMensajeSeleccionCalculo}"
                        BackgroundColor="#FEF2F2"
                        Stroke="#FECACA"
                        Padding="10"
                        StrokeShape="RoundRectangle 10">

                        <Label
                            Text="{Binding MensajeSeleccionCalculo}"
                            TextColor="#991B1B"
                            FontSize="14"
                            LineBreakMode="WordWrap" />
                    </Border>

                    <Button
                        Text="Procesar selección"
                        BackgroundColor="#3B655B"
                        TextColor="White"
                        CornerRadius="12"
                        HeightRequest="48"
                        Command="{Binding ProcesarSeleccionCommand}" />

                    <Button
                        Text="Volver"
                        BackgroundColor="#E5E7EB"
                        TextColor="Black"
                        CornerRadius="12"
                        HeightRequest="45"
                        Command="{Binding VolverCommand}" />

                </VerticalStackLayout>
            </Border>

            <BoxView HeightRequest="12" Color="Transparent" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
