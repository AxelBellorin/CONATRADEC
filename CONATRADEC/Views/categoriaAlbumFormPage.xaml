<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CONATRADEC.Views.categoriaAlbumFormPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{OnPlatform WinUI='#F4F7F5', Default={StaticResource color_Blanco}}">

    <Grid RowDefinitions="Auto,*">
        <Grid
            Grid.Row="0"
            Padding="{OnPlatform WinUI='26,18', Default='16,12'}"
            ColumnDefinitions="Auto,*"
            ColumnSpacing="10"
            BackgroundColor="White">

            <Button
                Grid.Column="0"
                Text="← Regresar"
                Command="{Binding CancelarCommand}"
                BackgroundColor="Transparent"
                TextColor="{StaticResource color_Verde}"
                FontAttributes="Bold" />

            <Label
                Grid.Column="1"
                Text="{Binding TituloPagina}"
                VerticalOptions="Center"
                FontFamily="MontserratBold"
                FontSize="21"
                FontAttributes="Bold"
                TextColor="{StaticResource color_Negro}" />
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout
                Padding="{OnPlatform WinUI='30,26,30,38', Default='16,18,16,28'}"
                MaximumWidthRequest="780"
                HorizontalOptions="Center"
                Spacing="18">

                <Border
                    Padding="{OnPlatform WinUI=28, Default=20}"
                    BackgroundColor="White"
                    Stroke="#DDE7E3"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 20">

                    <VerticalStackLayout Spacing="18">
                        <VerticalStackLayout Spacing="5">
                            <Label
                                Text="Información del capítulo"
                                FontFamily="MontserratBold"
                                FontSize="21"
                                FontAttributes="Bold"
                                TextColor="{StaticResource color_Verde}" />
                            <Label
                                Text="La categoría funciona como un capítulo principal del álbum."
                                FontSize="12"
                                TextColor="{StaticResource color_GrisOscuro}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="6">
                            <Label
                                Text="Nombre de la categoría *"
                                FontSize="13"
                                FontAttributes="Bold"
                                TextColor="{StaticResource color_Negro}" />
                            <Border
                                Padding="13,3"
                                BackgroundColor="#F8FAF9"
                                Stroke="#D6E1DC"
                                StrokeShape="RoundRectangle 12">
                                <Entry
                                    Text="{Binding Nombre}"
                                    Placeholder="Ejemplo: Enfermedades"
                                    MaxLength="100"
                                    BackgroundColor="Transparent"
                                    TextColor="{StaticResource color_Negro}" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="6">
                            <Label
                                Text="Introducción del capítulo"
                                FontSize="13"
                                FontAttributes="Bold"
                                TextColor="{StaticResource color_Negro}" />
                            <Border
                                Padding="10"
                                BackgroundColor="#F8FAF9"
                                Stroke="#D6E1DC"
                                StrokeShape="RoundRectangle 12">
                                <Editor
                                    Text="{Binding Descripcion}"
                                    Placeholder="Explique qué encontrará el usuario dentro de esta categoría."
                                    MaxLength="500"
                                    AutoSize="TextChanges"
                                    MinimumHeightRequest="130"
                                    BackgroundColor="Transparent"
                                    TextColor="{StaticResource color_Negro}" />
                            </Border>
                            <Label
                                Text="Máximo 500 caracteres."
                                FontSize="10"
                                TextColor="{StaticResource color_GrisOscuro}" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <Border
                    Padding="{OnPlatform WinUI=28, Default=20}"
                    BackgroundColor="White"
                    Stroke="#DDE7E3"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 20">

                    <VerticalStackLayout Spacing="14">
                        <Label
                            Text="Imagen de portada"
                            FontFamily="MontserratBold"
                            FontSize="19"
                            FontAttributes="Bold"
                            TextColor="{StaticResource color_Verde}" />

                        <Image
                            Source="{Binding ImagenActual}"
                            IsVisible="{Binding TieneImagenActual}"
                            HeightRequest="220"
                            Aspect="AspectFit" />

                        <Border
                            IsVisible="{Binding TieneImagenActual}"
                            Padding="10"
                            BackgroundColor="#F2F8F5"
                            Stroke="#C8DED6"
                            StrokeShape="RoundRectangle 10">
                            <Label
                                Text="La nueva imagen reemplazará la portada actual."
                                FontSize="11"
                                TextColor="{StaticResource color_Verde}" />
                        </Border>

                        <Button
                            Text="Seleccionar imagen"
                            Command="{Binding SeleccionarPortadaCommand}"
                            BackgroundColor="#EEF5F2"
                            TextColor="{StaticResource color_Verde}"
                            BorderColor="#C8DED6"
                            BorderWidth="1"
                            CornerRadius="12"
                            HeightRequest="48"
                            FontAttributes="Bold" />

                        <Label
                            Text="{Binding ArchivoSeleccionadoTexto}"
                            FontSize="11"
                            TextColor="{StaticResource color_GrisOscuro}"
                            HorizontalTextAlignment="Center" />

                        <Label
                            Text="Formatos permitidos: JPG, JPEG, PNG y WEBP. Tamaño máximo: 8 MB."
                            FontSize="10"
                            TextColor="{StaticResource color_GrisOscuro}"
                            HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>

                <ActivityIndicator
                    IsRunning="{Binding IsBusy}"
                    IsVisible="{Binding IsBusy}"
                    Color="{StaticResource color_Naranja}" />

                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <Button
                        Grid.Column="0"
                        Text="Cancelar"
                        Command="{Binding CancelarCommand}"
                        BackgroundColor="#F3F4F6"
                        TextColor="{StaticResource color_GrisOscuro}"
                        CornerRadius="12"
                        HeightRequest="52" />

                    <Button
                        Grid.Column="1"
                        Text="Guardar categoría"
                        Command="{Binding GuardarCommand}"
                        IsEnabled="{Binding NotIsBusy}"
                        BackgroundColor="{StaticResource color_Verde}"
                        TextColor="White"
                        CornerRadius="12"
                        HeightRequest="52"
                        FontAttributes="Bold" />
                </Grid>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
