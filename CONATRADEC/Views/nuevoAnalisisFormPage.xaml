<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CONATRADEC.Views.NuevoAnalisisFormPage"
             x:Name="NuevoAnalisisPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource color_Blanco}"
             Title="Nuevo Análisis">

    <ContentPage.Resources>

        <Style x:Key="FormInputContainerStyle"
               TargetType="Border"
               BasedOn="{StaticResource InputContainerStyle}">
            <Setter Property="HeightRequest" Value="64" />
            <Setter Property="Padding" Value="14,4" />
            <Setter Property="VerticalOptions" Value="Center" />
        </Style>

        <Style x:Key="FormEntryStyle"
               TargetType="Entry"
               BasedOn="{StaticResource InputEntryStyle}">
            <Setter Property="HeightRequest" Value="56" />
            <Setter Property="VerticalOptions" Value="Center" />
            <Setter Property="BackgroundColor" Value="Transparent" />
        </Style>

        <Style x:Key="FormPickerStyle"
               TargetType="Picker"
               BasedOn="{StaticResource InputPickerStyle}">
            <Setter Property="HeightRequest" Value="56" />
            <Setter Property="VerticalOptions" Value="Center" />
            <Setter Property="BackgroundColor" Value="Transparent" />
        </Style>

        <Style x:Key="FormSearchBarStyle"
               TargetType="SearchBar">
            <Setter Property="HeightRequest" Value="56" />
            <Setter Property="VerticalOptions" Value="Center" />
            <Setter Property="BackgroundColor" Value="Transparent" />
            <Setter Property="TextColor" Value="{StaticResource color_Negro}" />
            <Setter Property="PlaceholderColor" Value="{StaticResource color_Gris}" />
        </Style>

        <Style x:Key="FormDatePickerStyle"
               TargetType="DatePicker">
            <Setter Property="HeightRequest" Value="56" />
            <Setter Property="VerticalOptions" Value="Center" />
            <Setter Property="BackgroundColor" Value="Transparent" />
            <Setter Property="TextColor" Value="{StaticResource color_Negro}" />
        </Style>

        <Style x:Key="ValidationErrorLabelStyle"
               TargetType="Label">
            <Setter Property="TextColor" Value="{StaticResource RedDelete}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="2,-2,0,0" />
            <Setter Property="FontAttributes" Value="Bold" />
        </Style>

    </ContentPage.Resources>

    <ContentView x:Name="UserPage"
                 ControlTemplate="{StaticResource FooterTemplate}">

        <Grid RowDefinitions="*,Auto">

            <ScrollView Grid.Row="0">
                <VerticalStackLayout Padding="18,14"
                                     Spacing="0"
                                     HorizontalOptions="Fill">

                    <VerticalStackLayout Spacing="8"
                                         Margin="0,4,0,24">

                        <Label Text="Formulario de Análisis de Suelo"
                               FontAttributes="Bold"
                               FontSize="30"
                               TextColor="{StaticResource color_Verde}" />

                        <Label Text="Ingrese los datos del terreno, laboratorio y valores reportados para iniciar el procesamiento nutricional."
                               FontSize="15"
                               TextColor="{StaticResource color_GrisOscuro}" />

                        <Border BackgroundColor="#EEF5F2"
                                Stroke="{StaticResource color_Verde}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 18"
                                Padding="16,8"
                                HorizontalOptions="Start">

                            <HorizontalStackLayout Spacing="8">
                                <BoxView WidthRequest="8"
                                         HeightRequest="8"
                                         CornerRadius="4"
                                         BackgroundColor="{StaticResource color_Verde}"
                                         VerticalOptions="Center" />

                                <Label Text="Nuevo análisis"
                                       TextColor="{StaticResource color_Verde}"
                                       FontAttributes="Bold"
                                       FontSize="13"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </Border>

                    </VerticalStackLayout>

                    <Border Style="{StaticResource CardAnalisisStyle}">

                        <VerticalStackLayout Spacing="18">

                            <HorizontalStackLayout Spacing="16">

                                <Border WidthRequest="66"
                                        HeightRequest="66"
                                        StrokeShape="Ellipse"
                                        Stroke="{StaticResource color_Verde}"
                                        StrokeThickness="2"
                                        BackgroundColor="{StaticResource color_Verde}"
                                        VerticalOptions="Start">

                                    <Grid>
                                        <Image Source="{Binding UrlImagenUsuario}"
                                               Aspect="AspectFill"
                                               IsVisible="{Binding TieneImagenUsuario}" />

                                        <Label Text="{Binding InicialesUsuario}"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"
                                               TextColor="{StaticResource color_Blanco}"
                                               FontAttributes="Bold"
                                               FontSize="18"
                                               IsVisible="{Binding NoTieneImagenUsuario}" />
                                    </Grid>
                                </Border>

                                <VerticalStackLayout Spacing="4"
                                                     VerticalOptions="Center"
                                                     HorizontalOptions="FillAndExpand">

                                    <Label Text="{Binding NombreCompletoUsuario}"
                                           FontAttributes="Bold"
                                           FontSize="20"
                                           TextColor="{StaticResource color_Negro}" />

                                    <Label Text="{Binding CorreoUsuario}"
                                           TextColor="{StaticResource color_GrisOscuro}"
                                           FontSize="14" />

                                </VerticalStackLayout>

                            </HorizontalStackLayout>

                        </VerticalStackLayout>
                    </Border>

                    <Border Style="{StaticResource CardAnalisisStyle}">

                        <VerticalStackLayout Spacing="16">

                            <VerticalStackLayout Spacing="4">
                                <Label Text="Cliente y terreno"
                                       Style="{StaticResource SectionTitleStyle}" />

                                <Label Text="Busque el cliente, código o nombre del terreno asociado al análisis de suelo."
                                       Style="{StaticResource SectionSubtitleStyle}" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="6">
                                <Label Text="Buscar cliente / terreno"
                                       Style="{StaticResource FieldLabelStyle}" />

                                <Border Style="{StaticResource FormInputContainerStyle}">
                                    <SearchBar Text="{Binding TextoBusquedaTerreno}"
                                               Placeholder="Buscar por cliente, código o nombre del terreno"
                                               SearchCommand="{Binding BuscarTerrenoCommand}"
                                               Style="{StaticResource FormSearchBarStyle}" />
                                </Border>

                                <Label Text="{Binding ErrorTerreno}"
                                       IsVisible="{Binding TieneErrorTerreno}"
                                       Style="{StaticResource ValidationErrorLabelStyle}" />
                            </VerticalStackLayout>

                            <CollectionView ItemsSource="{Binding TerrenosFiltrados}"
                                            SelectionMode="None"
                                            HeightRequest="260">

                                <CollectionView.ItemTemplate>
                                    <DataTemplate>

                                        <Border BackgroundColor="#F9FAFB"
                                                Stroke="#E5E7EB"
                                                StrokeThickness="1"
                                                StrokeShape="RoundRectangle 14"
                                                Padding="12"
                                                Margin="0,0,0,8">

                                            <VerticalStackLayout Spacing="8">

                                                <Label Text="{Binding NombreCliente}"
                                                       FontAttributes="Bold"
                                                       FontSize="15"
                                                       TextColor="{StaticResource color_Negro}" />

                                                <Label Text="{Binding CodigoTerreno}"
                                                       FontAttributes="Bold"
                                                       FontSize="13"
                                                       TextColor="{StaticResource color_Verde}" />

                                                <Label Text="{Binding NombreTerreno}"
                                                       FontSize="13"
                                                       TextColor="{StaticResource color_GrisOscuro}" />

                                                <Label Text="{Binding TamanoFinca, StringFormat='Finca: {0} mz'}"
                                                       FontSize="13"
                                                       TextColor="{StaticResource color_GrisOscuro}" />

                                                <Label Text="{Binding CantidadQuintalesOro, StringFormat='Quintales oro: {0}'}"
                                                       FontSize="13"
                                                       TextColor="{StaticResource color_GrisOscuro}" />
                                                    
                                                <Label Text="{Binding CantidadPlantasTerreno, StringFormat='Plantas: {0}'}"
                                                       FontSize="13"
                                                       TextColor="{StaticResource color_GrisOscuro}" />

                                                <Button Text="Seleccionar terreno"
                                                        Style="{StaticResource AddButton}"
                                                        FontSize="13"
                                                        Padding="10,8"
                                                        Command="{Binding BindingContext.SeleccionarTerrenoCommand, Source={x:Reference NuevoAnalisisPage}}"
                                                        CommandParameter="{Binding .}" />

                                            </VerticalStackLayout>

                                        </Border>

                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>

                            <Border BackgroundColor="#EEF5F2"
                                    Stroke="{StaticResource color_Verde}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 14"
                                    Padding="12"
                                    IsVisible="{Binding TieneTerrenoSeleccionado}">

                                <VerticalStackLayout Spacing="4">

                                    <Label Text="Terreno seleccionado"
                                           FontAttributes="Bold"
                                           FontSize="14"
                                           TextColor="{StaticResource color_Verde}" />

                                    <Label Text="{Binding TerrenoSeleccionado.NombreCliente}"
                                           FontAttributes="Bold"
                                           FontSize="15"
                                           TextColor="{StaticResource color_Negro}" />

                                    <Label Text="{Binding TerrenoSeleccionado.NombreTerreno}"
                                           FontSize="13"
                                           TextColor="{StaticResource color_GrisOscuro}" />

                                    <Label Text="{Binding TerrenoSeleccionado.CodigoTerreno}"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource color_Cafe}" />

                                    <Label Text="{Binding TerrenoSeleccionado.CantidadPlantasTerreno, StringFormat='Plantas registradas: {0}'}"
                                           FontSize="13"
                                           TextColor="{StaticResource color_GrisOscuro}" />

                                </VerticalStackLayout>
                            </Border>

                        </VerticalStackLayout>
                    </Border>

                    <Border Style="{StaticResource CardAnalisisStyle}">

                        <VerticalStackLayout Spacing="16">

                            <VerticalStackLayout Spacing="4">
                                <Label Text="Datos del análisis"
                                       Style="{StaticResource SectionTitleStyle}" />

                                <Label Text="Complete la información general del análisis emitido por el laboratorio."
                                       Style="{StaticResource SectionSubtitleStyle}" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="6">
                                <Label Text="Tipo de cultivo"
                                        Style="{StaticResource FieldLabelStyle}" />

                                <Border Style="{StaticResource FormInputContainerStyle}">
                                    <Picker ItemsSource="{Binding TiposCultivo}"
                                            SelectedItem="{Binding TipoCultivoSeleccionado, Mode=TwoWay}"
                                            ItemDisplayBinding="{Binding NombreMostrar}"
                                            Title="Seleccione cultivo"
                                            Style="{StaticResource FormPickerStyle}" />
                                </Border>

                                <Label Text="{Binding ErrorTipoCultivo}"
                                       IsVisible="{Binding TieneErrorTipoCultivo}"
                                       Style="{StaticResource ValidationErrorLabelStyle}" />
                            </VerticalStackLayout>
                            

                            <VerticalStackLayout Spacing="6">
                                <Label Text="Tipo de análisis de suelo"
                                       Style="{StaticResource FieldLabelStyle}" />

                                <Border Style="{StaticResource FormInputContainerStyle}">
                                    <Picker ItemsSource="{Binding TiposAnalisisSuelo}"
                                            SelectedItem="{Binding TipoAnalisisSueloSeleccionado}"
                                            Title="Seleccione análisis"
                                            Style="{StaticResource FormPickerStyle}" />
                                </Border>

                                <Label Text="{Binding ErrorTipoAnalisisSuelo}"
                                       IsVisible="{Binding TieneErrorTipoAnalisisSuelo}"
                                       Style="{StaticResource ValidationErrorLabelStyle}" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="6">
                                <Label Text="Fecha del análisis del laboratorio"
                                       Style="{StaticResource FieldLabelStyle}" />

                                <Border Style="{StaticResource FormInputContainerStyle}">
                                    <DatePicker Date="{Binding FechaAnalisisLaboratorio}"
                                                Style="{StaticResource FormDatePickerStyle}" />
                                </Border>

                                <Label Text="{Binding ErrorFechaAnalisisLaboratorio}"
                                       IsVisible="{Binding TieneErrorFechaAnalisisLaboratorio}"
                                       Style="{StaticResource ValidationErrorLabelStyle}" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="6">
                                <Label Text="Laboratorio análisis de suelo"
                                       Style="{StaticResource FieldLabelStyle}" />

                                <Border Style="{StaticResource FormInputContainerStyle}">
                                    <Entry Text="{Binding Laboratorio}"
                                           Placeholder="Nombre del laboratorio"
                                           HorizontalOptions="Fill"
                                           Style="{StaticResource FormEntryStyle}" />
                                </Border>

                                <Label Text="{Binding ErrorLaboratorio}"
                                       IsVisible="{Binding TieneErrorLaboratorio}"
                                       Style="{StaticResource ValidationErrorLabelStyle}" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="6">
                                <Label Text="Identificador de análisis de suelo"
                                       Style="{StaticResource FieldLabelStyle}" />

                                <Border Style="{StaticResource FormInputContainerStyle}">
                                    <Entry Text="{Binding IdentificadorAnalisisSuelo}"
                                           Placeholder="Código único del laboratorio"
                                           HorizontalOptions="Fill"
                                           Style="{StaticResource FormEntryStyle}" />
                                </Border>

                                <Label Text="{Binding ErrorIdentificadorAnalisisSuelo}"
                                       IsVisible="{Binding TieneErrorIdentificadorAnalisisSuelo}"
                                       Style="{StaticResource ValidationErrorLabelStyle}" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="6">
                                <Label Text="Cantidad quintales oro"
                                       Style="{StaticResource FieldLabelStyle}" />

                                <Border Style="{StaticResource FormInputContainerStyle}">
                                    <Entry Text="{Binding CantidadQuintalesOro}"
                                           Keyboard="Numeric"
                                           Placeholder="Ejemplo: 25"
                                           HorizontalOptions="Fill"
                                           Style="{StaticResource FormEntryStyle}" />
                                </Border>

                                <Label Text="{Binding ErrorCantidadQuintalesOro}"
                                       IsVisible="{Binding TieneErrorCantidadQuintalesOro}"
                                       Style="{StaticResource ValidationErrorLabelStyle}" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="6">
                                <Label Text="Tamaño de la finca"
                                       Style="{StaticResource FieldLabelStyle}" />

                                <Border Style="{StaticResource FormInputContainerStyle}">
                                    <Entry Text="{Binding TamanoFinca}"
                                           Keyboard="Numeric"
                                           Placeholder="Ejemplo: 3.5"
                                           HorizontalOptions="Fill"
                                           Style="{StaticResource FormEntryStyle}" />
                                </Border>

                                <Label Text="{Binding ErrorTamanoFinca}"
                                       IsVisible="{Binding TieneErrorTamanoFinca}"
                                       Style="{StaticResource ValidationErrorLabelStyle}" />

                                <Label Text="Este valor viene del terreno, pero puede modificarse si es necesario."
                                       FontSize="12"
                                       TextColor="{StaticResource color_GrisOscuro}" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="6">
                                <Label Text="Cantidad de plantas"
                                       Style="{StaticResource FieldLabelStyle}" />

                                        <Border Style="{StaticResource FormInputContainerStyle}">
                                            <Entry Text="{Binding CantidadPlantas}"
                                                    Keyboard="Numeric"
                                                    Placeholder="Ejemplo: 3500"
                                                    HorizontalOptions="Fill"
                                                    Style="{StaticResource FormEntryStyle}" />
                                        </Border>

                                        <Label Text="{Binding ErrorCantidadPlantas}"
                                               IsVisible="{Binding TieneErrorCantidadPlantas}"
                                               Style="{StaticResource ValidationErrorLabelStyle}" />

                                        <Label Text="Este valor viene del terreno, pero puede modificarse si es necesario para calcular aplicaciones."
                                                FontSize="12"
                                                TextColor="{StaticResource color_GrisOscuro}" />
                            </VerticalStackLayout>

                        </VerticalStackLayout>
                    </Border>

                    <Border Style="{StaticResource CardAnalisisStyle}">

                        <VerticalStackLayout Spacing="16">

                            <VerticalStackLayout Spacing="4">
                                <Label Text="Parámetros constantes"
                                       Style="{StaticResource SectionTitleStyle}" />

                                <Label Text="Estos parámetros forman parte fija del análisis de suelo y no se pueden quitar."
                                       Style="{StaticResource SectionSubtitleStyle}" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="12"
                                                 BindableLayout.ItemsSource="{Binding ParametrosConstantesAnalisis}">

                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>

                                        <Border BackgroundColor="#F9FAFB"
                                                Stroke="#E5E7EB"
                                                StrokeThickness="1"
                                                StrokeShape="RoundRectangle 14"
                                                Padding="14"
                                                Margin="0,0,0,4">

                                            <VerticalStackLayout Spacing="10">

                                                <Label Text="{Binding NombreParametro}"
                                                       FontAttributes="Bold"
                                                       FontSize="15"
                                                       TextColor="{StaticResource color_Negro}" />

                                                <Label Text="Parámetro constante"
                                                       FontSize="12"
                                                       TextColor="{StaticResource color_GrisOscuro}" />

                                                <VerticalStackLayout Spacing="6">
                                                    <Label Text="Valor reportado"
                                                           FontSize="13"
                                                           FontAttributes="Bold"
                                                           TextColor="{StaticResource color_GrisOscuro}" />

                                                    <Border Style="{StaticResource FormInputContainerStyle}">
                                                        <Entry Text="{Binding Valor}"
                                                               Keyboard="Numeric"
                                                               Placeholder="{Binding PlaceholderValor}"
                                                               HorizontalOptions="Fill"
                                                               Style="{StaticResource FormEntryStyle}" />
                                                    </Border>
                                                </VerticalStackLayout>

                                                <VerticalStackLayout Spacing="6">
                                                    <Label Text="Unidad"
                                                           FontSize="13"
                                                           FontAttributes="Bold"
                                                           TextColor="{StaticResource color_GrisOscuro}" />

                                                    <Border Style="{StaticResource FormInputContainerStyle}">
                                                        <Picker ItemsSource="{Binding UnidadesMedida}"
                                                                SelectedItem="{Binding UnidadSeleccionada}"
                                                                ItemDisplayBinding="{Binding TextoMostrar}"
                                                                Style="{StaticResource FormPickerStyle}" />
                                                    </Border>
                                                </VerticalStackLayout>
                                            </VerticalStackLayout>
                                        </Border>

                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>

                        </VerticalStackLayout>
                    </Border>

                    <Border Style="{StaticResource CardAnalisisStyle}">

                        <VerticalStackLayout Spacing="16">

                            <VerticalStackLayout Spacing="4">
                                <Label Text="Elementos químicos"
                                       Style="{StaticResource SectionTitleStyle}" />

                                <Label Text="Estos elementos se cargan dinámicamente desde el catálogo de elementos químicos. Puede quitar los que no aparecen en el reporte del laboratorio."
                                       Style="{StaticResource SectionSubtitleStyle}" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="12"
                                                 BindableLayout.ItemsSource="{Binding ElementosQuimicosAnalisis}">

                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>

                                        <Border BackgroundColor="#F9FAFB"
                                                Stroke="#E5E7EB"
                                                StrokeThickness="1"
                                                StrokeShape="RoundRectangle 14"
                                                Padding="14"
                                                Margin="0,0,0,4">

                                            <VerticalStackLayout Spacing="10">

                                                <Grid ColumnDefinitions="*,Auto"
                                                      ColumnSpacing="10">

                                                    <VerticalStackLayout Grid.Column="0"
                                                                         Spacing="2">
                                                        <Label Text="{Binding NombreParametro}"
                                                               FontAttributes="Bold"
                                                               FontSize="15"
                                                               TextColor="{StaticResource color_Negro}" />

                                                        <Label Text="Elemento químico"
                                                               FontSize="12"
                                                               TextColor="{StaticResource color_GrisOscuro}" />
                                                    </VerticalStackLayout>

                                                    <Button Grid.Column="1"
                                                            Text="Quitar"
                                                            Style="{StaticResource DeleteButton}"
                                                            FontSize="12"
                                                            Padding="10,6"
                                                            IsVisible="{Binding PuedeEliminar}"
                                                            Command="{Binding BindingContext.QuitarElementoQuimicoCommand, Source={x:Reference NuevoAnalisisPage}}"
                                                            CommandParameter="{Binding .}" />
                                                </Grid>

                                                <VerticalStackLayout Spacing="6">
                                                    <Label Text="Valor reportado"
                                                           FontSize="13"
                                                           FontAttributes="Bold"
                                                           TextColor="{StaticResource color_GrisOscuro}" />

                                                    <Border Style="{StaticResource FormInputContainerStyle}">
                                                        <Entry Text="{Binding Valor}"
                                                               Keyboard="Numeric"
                                                               Placeholder="{Binding PlaceholderValor}"
                                                               HorizontalOptions="Fill"
                                                               Style="{StaticResource FormEntryStyle}" />
                                                    </Border>
                                                </VerticalStackLayout>

                                                <VerticalStackLayout Spacing="6">
                                                    <Label Text="Unidad"
                                                           FontSize="13"
                                                           FontAttributes="Bold"
                                                           TextColor="{StaticResource color_GrisOscuro}" />

                                                    <Border Style="{StaticResource FormInputContainerStyle}">
                                                        <Picker ItemsSource="{Binding UnidadesMedida}"
                                                                SelectedItem="{Binding UnidadSeleccionada}"
                                                                ItemDisplayBinding="{Binding TextoMostrar}"
                                                                Style="{StaticResource FormPickerStyle}" />
                                                    </Border>
                                                </VerticalStackLayout>
                                            </VerticalStackLayout>
                                        </Border>

                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>

                        </VerticalStackLayout>
                    </Border>

                    <Border BackgroundColor="#EEF5F2"
                            Stroke="Transparent"
                            StrokeShape="RoundRectangle 16"
                            Padding="16"
                            Margin="0,0,0,18">

                        <HorizontalStackLayout Spacing="12">

                            <Border WidthRequest="34"
                                    HeightRequest="34"
                                    StrokeShape="Ellipse"
                                    BackgroundColor="{StaticResource color_Verde}"
                                    VerticalOptions="Start">

                                <Label Text="i"
                                       TextColor="{StaticResource color_Blanco}"
                                       FontAttributes="Bold"
                                       FontSize="18"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>

                            <Label Text="Al enviar el análisis, el sistema validará los valores capturados y preparará los datos para conversión, clasificación y procesamiento nutricional."
                                   TextColor="{StaticResource color_Verde}"
                                   FontSize="14"
                                   VerticalOptions="Center"
                                   HorizontalOptions="FillAndExpand" />
                        </HorizontalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </ScrollView>

            <Border Grid.Row="1"
                    BackgroundColor="White"
                    Stroke="#E5E7EB"
                    StrokeThickness="1"
                    Padding="18,12">

                <VerticalStackLayout Spacing="10">

                    <Label Text="Revise que los valores coincidan con el reporte del laboratorio antes de enviar."
                           FontSize="13"
                           TextColor="{StaticResource color_GrisOscuro}" />

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="10">

                        <Button Grid.Column="0"
                                Text="Cancelar"
                                Command="{Binding CancelarCommand}"
                                Style="{StaticResource CancelButton}" />

                        <Button Grid.Column="1"
                                Text="Enviar Análisis"
                                Command="{Binding EnviarAnalisisCommand}"
                                Style="{StaticResource AddButton}"
                                IsEnabled="{Binding PuedeEnviar}" />
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <Grid Grid.RowSpan="2"
                  BackgroundColor="#80000000"
                  IsVisible="{Binding IsBusy}">

                <VerticalStackLayout HorizontalOptions="Center"
                                     VerticalOptions="Center"
                                     Spacing="12">

                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       Color="{StaticResource color_Verde}"
                                       WidthRequest="42"
                                       HeightRequest="42" />

                    <Label Text="Procesando análisis..."
                           TextColor="White"
                           FontSize="16"
                           FontAttributes="Bold" />
                </VerticalStackLayout>
            </Grid>

        </Grid>
    </ContentView>
</ContentPage>