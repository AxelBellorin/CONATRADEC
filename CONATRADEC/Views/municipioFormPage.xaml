<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="CONATRADEC.Views.municipioFormPage"
    Title="Formulario de municipio"
    Shell.NavBarIsVisible="False"
    Background="Transparent">

    <Grid RowDefinitions="Auto,*">

        <Grid
            Grid.Row="0"
            ColumnDefinitions="*,Auto"
            Margin="10,20,20,0">

            <Label
                Text="{Binding Title}"
                TextColor="{StaticResource color_Verde}"
                FontSize="24"
                FontFamily="MontserratBold"
                FontAttributes="Bold"
                HorizontalOptions="Start"
                VerticalOptions="Center" />

            <ActivityIndicator
                Grid.Column="1"
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}"
                Color="{StaticResource color_Naranja}"
                VerticalOptions="Center" />

        </Grid>

        <ScrollView Grid.Row="1">

            <VerticalStackLayout
                Padding="10"
                Spacing="15">

                <Border
                    Style="{StaticResource ValidationFieldContainerStyle}">

                    <Border.Triggers>
                        <DataTrigger
                            TargetType="Border"
                            Binding="{Binding TieneErrorNombreMunicipio}"
                            Value="True">
                            <Setter
                                Property="Stroke"
                                Value="{StaticResource RedDelete}" />
                            <Setter
                                Property="StrokeThickness"
                                Value="2" />
                        </DataTrigger>
                    </Border.Triggers>

                    <VerticalStackLayout Spacing="5">

                        <Label
                            Text="Nombre del municipio"
                            FontAttributes="Bold"
                            FontFamily="MontserratBold"
                            FontSize="14"
                            TextColor="{StaticResource color_Negro}" />

                        <Entry
                            Placeholder="Ingrese el nombre del municipio"
                            Style="{StaticResource EntryStyle}"
                            Text="{Binding NombreMunicipio}"
                            IsReadOnly="{Binding IsReadOnly}" />

                        <Label
                            Text="{Binding ErrorNombreMunicipio}"
                            IsVisible="{Binding TieneErrorNombreMunicipio}"
                            Style="{StaticResource ValidationMessageStyle}" />

                    </VerticalStackLayout>

                </Border>

                <Grid
                    ColumnDefinitions="*,*"
                    Margin="10,0,10,20">

                    <Button
                        Grid.Column="0"
                        Text="Guardar"
                        Style="{StaticResource UpdateButton}"
                        IsVisible="{Binding ShowSaveButton}"
                        IsEnabled="{Binding NotIsBusy}"
                        Command="{Binding SaveCommand}"
                        Margin="10,0" />

                    <Button
                        Grid.Column="1"
                        Text="Cancelar"
                        Style="{StaticResource CancelButton}"
                        IsEnabled="{Binding NotIsBusy}"
                        Command="{Binding CancelCommand}"
                        Margin="10,0" />

                </Grid>

            </VerticalStackLayout>

        </ScrollView>

    </Grid>

</ContentPage>
