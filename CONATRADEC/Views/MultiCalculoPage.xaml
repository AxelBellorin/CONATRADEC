<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CONATRADEC.Views.MultiCalculoPage"
    x:Name="MultiCalculoRoot"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Cálculos complementarios"
    BackgroundColor="{StaticResource color_Blanco}"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto">

        <Border
            Grid.Row="0"
            Margin="18,14,18,0"
            BackgroundColor="{StaticResource color_Verde}"
            StrokeThickness="0"
            Padding="18"
            StrokeShape="RoundRectangle 18">

            <VerticalStackLayout Spacing="6">
                <Label
                    Text="Cálculos complementarios"
                    TextColor="White"
                    FontSize="25"
                    FontAttributes="Bold" />

                <Label
                    Text="{Binding TextoEncabezado}"
                    TextColor="White"
                    FontSize="14"
                    Opacity="0.9"
                    LineBreakMode="WordWrap" />
            </VerticalStackLayout>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="18,14" Spacing="16">

                <Border
                    BackgroundColor="White"
                    Stroke="#E5E7EB"
                    Padding="16"
                    StrokeShape="RoundRectangle 16">

                    <VerticalStackLayout Spacing="12">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="10">
                            <Label
                                Grid.Column="0"
                                Text="Datos base del análisis"
                                FontSize="18"
                                FontAttributes="Bold"
                                TextColor="{StaticResource color_Verde}" />

                            <Border
                                Grid.Column="1"
                                BackgroundColor="#EEF5F2"
                                Stroke="{StaticResource color_Verde}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 12"
                                Padding="10,5">
                                <Label
                                    Text="{Binding NombreTabActual}"
                                    FontSize="12"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource color_Verde}" />
                            </Border>
                        </Grid>

                        <Border
                            BackgroundColor="#F9FAFB"
                            Stroke="#E5E7EB"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 14"
                            Padding="12">
                            <VerticalStackLayout Spacing="4">
                                <Label
                                    Text="Nombre / identificador del análisis"
                                    FontSize="12"
                                    TextColor="{StaticResource color_GrisOscuro}" />

                                <Label
                                    Text="{Binding NombreAnalisisSuelo}"
                                    FontSize="17"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource color_Cafe}" />

                                <Label
                                    Text="Este nombre se reutiliza para balance, enmienda calcárea y fertilización mixta."
                                    FontSize="12"
                                    TextColor="{StaticResource color_GrisOscuro}"
                                    LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                        </Border>

                        <Grid
                            ColumnDefinitions="*,*"
                            RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                            ColumnSpacing="12"
                            RowSpacing="10">

                            <VerticalStackLayout Grid.Row="0" Grid.Column="0">
                                <Label Text="Tipo cultivo"
                                       FontSize="12"
                                       TextColor="{StaticResource color_GrisOscuro}" />
                                <Label Text="{Binding TipoCultivo}"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource color_Negro}" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="0" Grid.Column="1">
                                <Label Text="Tipo análisis"
                                       FontSize="12"
                                       TextColor="{StaticResource color_GrisOscuro}" />
                                <Label Text="{Binding TipoAnalisisSuelo}"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource color_Negro}" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="1" Grid.Column="0">
                                <Label Text="pH"
                                       FontSize="12"
                                       TextColor="{StaticResource color_GrisOscuro}" />
                                <Label Text="{Binding Ph, StringFormat='{0:N2}'}"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource color_Negro}" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="1" Grid.Column="1">
                                <Label Text="Acidez total / AT"
                                       FontSize="12"
                                       TextColor="{StaticResource color_GrisOscuro}" />
                                <Label Text="{Binding AcidezTotal, StringFormat='{0:N2}'}"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource color_Negro}" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="2" Grid.Column="0">
                                <Label Text="Calcio CICE"
                                       FontSize="12"
                                       TextColor="{StaticResource color_GrisOscuro}" />
                                <Label Text="{Binding CalcioCice, StringFormat='{0:N2}'}"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource color_Negro}" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="2" Grid.Column="1">
                                <Label Text="Magnesio CICE"
                                       FontSize="12"
                                       TextColor="{StaticResource color_GrisOscuro}" />
                                <Label Text="{Binding MagnesioCice, StringFormat='{0:N2}'}"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource color_Negro}" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="3" Grid.Column="0">
                                <Label Text="Potasio CICE"
                                       FontSize="12"
                                       TextColor="{StaticResource color_GrisOscuro}" />
                                <Label Text="{Binding PotasioCice, StringFormat='{0:N2}'}"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource color_Negro}" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="4" Grid.Column="0">
                                <Label Text="Tamaño finca"
                                       FontSize="12"
                                       TextColor="{StaticResource color_GrisOscuro}" />
                                <Label Text="{Binding TamanoFinca, StringFormat='{0:N2} mz'}"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource color_Negro}" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="4" Grid.Column="1">
                                <Label Text="Plantas"
                                       FontSize="12"
                                       TextColor="{StaticResource color_GrisOscuro}" />
                                <Label Text="{Binding CantidadPlantasTexto}"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource color_Negro}" />
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!--
                    Solo se inserta la vista de la pestaña activa.
                    En Android evita construir y medir simultáneamente las
                    tres interfaces completas de cálculos.
                -->
                <Grid x:Name="ContenidoTabActual" />

                <Border
                    IsVisible="{Binding TieneMensaje}"
                    BackgroundColor="#EEF5F2"
                    Stroke="#D1FAE5"
                    Padding="12"
                    StrokeShape="RoundRectangle 12">
                    <Label
                        Text="{Binding Mensaje}"
                        FontSize="14"
                        TextColor="{StaticResource color_Verde}"
                        LineBreakMode="WordWrap" />
                </Border>

                <BoxView HeightRequest="16" Color="Transparent" />
            </VerticalStackLayout>
        </ScrollView>

        <Border
            Grid.Row="2"
            BackgroundColor="White"
            Stroke="#E5E7EB"
            StrokeThickness="1"
            Padding="12,10">

            <VerticalStackLayout Spacing="10">
                <Grid ColumnDefinitions="*,*,*"
                      ColumnSpacing="8">

                    <Button
                        Grid.Column="0"
                        Text="Balance"
                        Command="{Binding SeleccionarBalanceCommand}"
                        IsVisible="{Binding MostrarBalanceFormula}"
                        HeightRequest="48"
                        CornerRadius="16"
                        BackgroundColor="#E5E7EB"
                        TextColor="Black"
                        FontAttributes="Bold"
                        FontSize="13">
                        <Button.Triggers>
                            <DataTrigger
                                TargetType="Button"
                                Binding="{Binding EsBalanceSeleccionado}"
                                Value="True">
                                <Setter Property="BackgroundColor" Value="{StaticResource color_Verde}" />
                                <Setter Property="TextColor" Value="White" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>

                    <Button
                        Grid.Column="1"
                        Text="Enmienda"
                        Command="{Binding SeleccionarEnmiendaCommand}"
                        IsVisible="{Binding MostrarEnmiendaCalcarea}"
                        HeightRequest="48"
                        CornerRadius="16"
                        BackgroundColor="#E5E7EB"
                        TextColor="Black"
                        FontAttributes="Bold"
                        FontSize="13">
                        <Button.Triggers>
                            <DataTrigger
                                TargetType="Button"
                                Binding="{Binding EsEnmiendaSeleccionada}"
                                Value="True">
                                <Setter Property="BackgroundColor" Value="{StaticResource color_Cafe}" />
                                <Setter Property="TextColor" Value="White" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>

                    <Button
                        Grid.Column="2"
                        Text="Mixta"
                        Command="{Binding SeleccionarFertilizacionCommand}"
                        IsVisible="{Binding MostrarFertilizacionMixta}"
                        HeightRequest="48"
                        CornerRadius="16"
                        BackgroundColor="#E5E7EB"
                        TextColor="Black"
                        FontAttributes="Bold"
                        FontSize="13">
                        <Button.Triggers>
                            <DataTrigger
                                TargetType="Button"
                                Binding="{Binding EsFertilizacionSeleccionada}"
                                Value="True">
                                <Setter Property="BackgroundColor" Value="#F2C94C" />
                                <Setter Property="TextColor" Value="Black" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                </Grid>

                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="10">
                    <Button
                        Grid.Column="0"
                        Text="Volver"
                        Command="{Binding VolverCommand}"
                        Style="{StaticResource CancelButton}" />

                    <Button
                        Grid.Column="1"
                        Text="{Binding TextoBotonGuardar}"
                        Command="{Binding GuardarCommand}"
                        Style="{StaticResource AddButton}" />
                </Grid>
            </VerticalStackLayout>
        </Border>

        <Grid
            Grid.RowSpan="3"
            BackgroundColor="#80000000"
            IsVisible="{Binding IsBusy}">
            <VerticalStackLayout
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Spacing="12">
                <ActivityIndicator
                    IsRunning="{Binding IsBusy}"
                    Color="{StaticResource color_Verde}"
                    WidthRequest="42"
                    HeightRequest="42" />
                <Label
                    Text="Guardando análisis..."
                    TextColor="White"
                    FontSize="16"
                    FontAttributes="Bold" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>
