                                            <VerticalStackLayout
                                                Spacing="0"
                                                BindableLayout.ItemsSource="{Binding Source={x:Reference DetallePageRoot}, Path=FilasCompraAjustadaVisual}">

                                                <BindableLayout.ItemTemplate>

                                                    <DataTemplate
                                                        x:DataType="viewModels:CompraComercialComplementoVisualViewModel">

                                                        <Grid
                                                            ColumnDefinitions="210,135,155,145,145,125,125,125,130,105,145"
                                                            MinimumWidthRequest="1500"
                                                            BackgroundColor="#F9FAFB">

                                                            <Label Grid.Column="0" Text="{Binding Fuente}" Padding="8" FontAttributes="Bold" TextColor="{StaticResource color_Negro}" />
                                                            <Label Grid.Column="1" Text="{Binding Elemento}" Padding="8" FontAttributes="Bold" TextColor="{StaticResource color_Cafe}" LineBreakMode="NoWrap" />
                                                            <Label Grid.Column="2" Text="{Binding TextoRequerimientoOriginal}" Padding="8" HorizontalTextAlignment="End" />
                                                            <Label Grid.Column="3" Text="{Binding TextoAporteOrganico}" Padding="8" HorizontalTextAlignment="End" TextColor="{StaticResource color_Verde}" />
                                                            <Label Grid.Column="4" Text="{Binding TextoRequerimientoRestante}" Padding="8" HorizontalTextAlignment="End" FontAttributes="Bold" TextColor="{StaticResource RedDelete}" />
                                                            <Label Grid.Column="5" Text="{Binding TextoQuintalesOriginales}" Padding="8" HorizontalTextAlignment="End" />
                                                            <Label Grid.Column="6" Text="{Binding TextoQuintalesAjustados}" Padding="8" HorizontalTextAlignment="End" />
                                                            <Label Grid.Column="7" Text="{Binding TextoReduccionQuintales}" Padding="8" HorizontalTextAlignment="End" FontAttributes="Bold" TextColor="{StaticResource color_Verde}" />
                                                            <Label Grid.Column="8" Text="{Binding TextoPrecioPorQq}" Padding="8" HorizontalTextAlignment="End" />
                                                            <Label Grid.Column="9" Text="{Binding TextoQuintalesComprar}" Padding="8" HorizontalTextAlignment="End" FontAttributes="Bold" TextColor="{StaticResource color_Cafe}" />
                                                            <Label Grid.Column="10" Text="{Binding TextoCostoCompra}" Padding="8" HorizontalTextAlignment="End" FontAttributes="Bold" TextColor="{StaticResource color_Cafe}" />

                                                        </Grid>

                                                    </DataTemplate>

                                                </BindableLayout.ItemTemplate>

                                            </VerticalStackLayout>

                                        </VerticalStackLayout>

                                    </ScrollView>

                                </VerticalStackLayout>

                            </Border>

                            <!-- COSTO ORGÁNICO -->
                            <Border
                                BackgroundColor="White"
                                Stroke="#E5E7EB"
                                StrokeShape="RoundRectangle 16"
                                Padding="16"
                                IsVisible="{Binding Source={x:Reference DetallePageRoot}, Path=TieneTablaCostosOrganicosVisual}">

                                <VerticalStackLayout Spacing="14">

                                    <Label
                                        Text="Costo de fertilización mixta"
                                        FontSize="18"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource color_Verde}" />

                                    <ScrollView Orientation="Horizontal">

                                        <VerticalStackLayout Spacing="0">

                                            <Grid
                                                ColumnDefinitions="220,120,140,150"
                                                MinimumWidthRequest="630"
                                                BackgroundColor="{StaticResource color_Verde}">

                                                <Label Grid.Column="0" Text="Fuente orgánica" TextColor="White" FontAttributes="Bold" Padding="8" />
                                                <Label Grid.Column="1" Text="Cantidad QQ" TextColor="White" FontAttributes="Bold" Padding="8" HorizontalTextAlignment="End" />
                                                <Label Grid.Column="2" Text="Precio/QQ" TextColor="White" FontAttributes="Bold" Padding="8" HorizontalTextAlignment="End" />
                                                <Label Grid.Column="3" Text="Costo" TextColor="White" FontAttributes="Bold" Padding="8" HorizontalTextAlignment="End" />

                                            </Grid>

                                            <VerticalStackLayout
                                                Spacing="0"
                                                BindableLayout.ItemsSource="{Binding Source={x:Reference DetallePageRoot}, Path=FilasCostoOrganicoVisual}">

                                                <BindableLayout.ItemTemplate>

                                                    <DataTemplate
                                                        x:DataType="viewModels:CostoFuenteOrganicaViewModel">

                                                        <Grid
                                                            ColumnDefinitions="220,120,140,150"
                                                            MinimumWidthRequest="630"
                                                            BackgroundColor="#F9FAFB">

                                                            <Label Grid.Column="0" Text="{Binding Fuente}" Padding="8" FontAttributes="Bold" />
                                                            <Label Grid.Column="1" Text="{Binding TextoCantidadQq}" Padding="8" HorizontalTextAlignment="End" />
                                                            <Label Grid.Column="2" Text="{Binding TextoPrecioPorQq}" Padding="8" HorizontalTextAlignment="End" />
                                                            <Label Grid.Column="3" Text="{Binding TextoCosto}" Padding="8" HorizontalTextAlignment="End" FontAttributes="Bold" TextColor="{StaticResource color_Cafe}" />

                                                        </Grid>

                                                    </DataTemplate>

                                                </BindableLayout.ItemTemplate>

                                            </VerticalStackLayout>

                                            <Grid
                                                ColumnDefinitions="220,120,140,150"
                                                MinimumWidthRequest="630"
                                                BackgroundColor="#EEF5F2">

                                                <Label
                                                    Grid.Column="0"
                                                    Grid.ColumnSpan="3"
                                                    Text="Total fertilización mixta"
                                                    Padding="8"
                                                    FontAttributes="Bold"
                                                    TextColor="{StaticResource color_Verde}" />

                                                <Label
                                                    Grid.Column="3"
                                                    Text="{Binding Source={x:Reference DetallePageRoot}, Path=TextoCostoFertilizacionMixtaVisual}"
                                                    Padding="8"
                                                    HorizontalTextAlignment="End"
                                                    FontAttributes="Bold"
                                                    TextColor="{StaticResource color_Verde}" />

                                            </Grid>

                                        </VerticalStackLayout>

                                    </ScrollView>

                                </VerticalStackLayout>

                            </Border>

                            <!-- COMPRA COMERCIAL AJUSTADA -->
                            <Border
                                BackgroundColor="White"
                                Stroke="#E5E7EB"
                                StrokeShape="RoundRectangle 16"
                                Padding="16"
                                IsVisible="{Binding Source={x:Reference DetallePageRoot}, Path=TieneCompraAjustadaVisual}">

                                <VerticalStackLayout Spacing="14">

                                    <VerticalStackLayout Spacing="4">

                                        <Label
                                            Text="Compra comercial ajustada"
                                            FontSize="18"
                                            FontAttributes="Bold"
                                            TextColor="{StaticResource color_Verde}" />

                                        <Label
                                            Text="Se mantienen las fuentes del balance original. Las cantidades a comprar se redondean al siguiente quintal entero."
                                            FontSize="13"
                                            TextColor="{StaticResource color_GrisOscuro}"
                                            LineBreakMode="WordWrap" />

                                    </VerticalStackLayout>

                                    <ScrollView Orientation="Horizontal">

                                        <VerticalStackLayout Spacing="0">

                                            <Grid
                                                ColumnDefinitions="220,135,135,135,130,145"
                                                MinimumWidthRequest="900"
                                                BackgroundColor="{StaticResource color_Verde}">

                                                <Label Grid.Column="0" Text="Fuente" TextColor="White" FontAttributes="Bold" Padding="8" />
                                                <Label Grid.Column="1" Text="Elemento" TextColor="White" FontAttributes="Bold" Padding="8" />
                                                <Label Grid.Column="2" Text="QQ ajustado" TextColor="White" FontAttributes="Bold" Padding="8" HorizontalTextAlignment="End" />
                                                <Label Grid.Column="3" Text="QQ comprar" TextColor="White" FontAttributes="Bold" Padding="8" HorizontalTextAlignment="End" />
                                                <Label Grid.Column="4" Text="Precio/QQ" TextColor="White" FontAttributes="Bold" Padding="8" HorizontalTextAlignment="End" />
                                                <Label Grid.Column="5" Text="Costo compra" TextColor="White" FontAttributes="Bold" Padding="8" HorizontalTextAlignment="End" />

                                            </Grid>

                                            <VerticalStackLayout
                                                Spacing="0"
                                                BindableLayout.ItemsSource="{Binding Source={x:Reference DetallePageRoot}, Path=FilasCompraAjustadaVisual}">

                                                <BindableLayout.ItemTemplate>

                                                    <DataTemplate
                                                        x:DataType="viewModels:CompraComercialComplementoVisualViewModel">

                                                        <Grid
                                                            ColumnDefinitions="220,135,135,135,130,145"
                                                            MinimumWidthRequest="900"
                                                            BackgroundColor="#F9FAFB">

                                                            <Label Grid.Column="0" Text="{Binding Fuente}" Padding="8" FontAttributes="Bold" />
                                                            <Label Grid.Column="1" Text="{Binding Elemento}" Padding="8" FontAttributes="Bold" TextColor="{StaticResource color_Cafe}" />
                                                            <Label Grid.Column="2" Text="{Binding TextoQuintalesAjustados}" Padding="8" HorizontalTextAlignment="End" />
                                                            <Label Grid.Column="3" Text="{Binding TextoQuintalesComprar}" Padding="8" HorizontalTextAlignment="End" FontAttributes="Bold" TextColor="{StaticResource color_Cafe}" />
                                                            <Label Grid.Column="4" Text="{Binding TextoPrecioPorQq}" Padding="8" HorizontalTextAlignment="End" />
                                                            <Label Grid.Column="5" Text="{Binding TextoCostoCompra}" Padding="8" HorizontalTextAlignment="End" FontAttributes="Bold" TextColor="{StaticResource color_Cafe}" />

                                                        </Grid>

                                                    </DataTemplate>

                                                </BindableLayout.ItemTemplate>

                                            </VerticalStackLayout>

                                        </VerticalStackLayout>

                                    </ScrollView>

                                </VerticalStackLayout>

                            </Border>

                            <!-- NO REQUIERE COMPRA -->
                            <Border
                                BackgroundColor="#EEF5F2"
                                Stroke="#D1FAE5"
                                StrokeShape="RoundRectangle 16"
                                Padding="16"
                                IsVisible="{Binding Source={x:Reference DetallePageRoot}, Path=NoRequiereCompraComercialVisual}">

                                <Label
                                    Text="El aporte orgánico cubre todos los requerimientos seleccionados del balance. No se requiere compra comercial ajustada."
                                    FontSize="14"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource color_Verde}"
                                    LineBreakMode="WordWrap" />

                            </Border>

                            <!-- RESUMEN ECONÓMICO -->
                            <Border
                                BackgroundColor="White"
                                Stroke="#E5E7EB"
                                StrokeShape="RoundRectangle 16"
                                Padding="16"
                                IsVisible="{Binding Source={x:Reference DetallePageRoot}, Path=TieneResumenEconomicoComplementoVisual}">

                                <VerticalStackLayout Spacing="12">

                                    <Label
                                        Text="Resumen económico del complemento"
                                        FontSize="18"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource color_Verde}" />

                                    <Grid
                                        ColumnDefinitions="*,Auto"
                                        RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                                        RowSpacing="10"
                                        ColumnSpacing="12">

                                        <Label Grid.Row="0" Grid.Column="0" Text="Costo comercial original" TextColor="{StaticResource color_GrisOscuro}" />
                                        <Label Grid.Row="0" Grid.Column="1" Text="{Binding Source={x:Reference DetallePageRoot}, Path=TextoCostoComercialOriginalVisual}" FontAttributes="Bold" />

                                        <Label Grid.Row="1" Grid.Column="0" Text="Costo fertilización mixta" TextColor="{StaticResource color_GrisOscuro}" />
                                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding Source={x:Reference DetallePageRoot}, Path=TextoCostoFertilizacionMixtaVisual}" FontAttributes="Bold" TextColor="{StaticResource color_Cafe}" />

                                        <Label Grid.Row="2" Grid.Column="0" Text="Costo comercial ajustado" TextColor="{StaticResource color_GrisOscuro}" />
                                        <Label Grid.Row="2" Grid.Column="1" Text="{Binding Source={x:Reference DetallePageRoot}, Path=TextoCostoComercialAjustadoVisual}" FontAttributes="Bold" TextColor="{StaticResource color_Cafe}" />

                                        <Label Grid.Row="3" Grid.Column="0" Text="Costo total final" FontAttributes="Bold" TextColor="{StaticResource color_Negro}" />
                                        <Label Grid.Row="3" Grid.Column="1" Text="{Binding Source={x:Reference DetallePageRoot}, Path=TextoCostoTotalFinalVisual}" FontAttributes="Bold" />

                                        <Label
                                            Grid.Row="4"
                                            Grid.Column="0"
                                            Text="{Binding Source={x:Reference DetallePageRoot}, Path=EtiquetaDiferenciaEconomicaVisual}"
                                            FontAttributes="Bold"
                                            TextColor="{Binding Source={x:Reference DetallePageRoot}, Path=ColorDiferenciaEconomicaVisual}" />

                                        <Label
                                            Grid.Row="4"
                                            Grid.Column="1"
                                            Text="{Binding Source={x:Reference DetallePageRoot}, Path=TextoDiferenciaEconomicaVisual}"
                                            FontAttributes="Bold"
                                            TextColor="{Binding Source={x:Reference DetallePageRoot}, Path=ColorDiferenciaEconomicaVisual}" />

                                    </Grid>

                                </VerticalStackLayout>

                            </Border>

                            <!-- MENSAJE DEL COMPLEMENTO -->
                            <Border
                                BackgroundColor="#FFF7ED"
                                Stroke="#FED7AA"
                                StrokeShape="RoundRectangle 12"
                                Padding="12"
                                IsVisible="{Binding Source={x:Reference DetallePageRoot}, Path=TieneMensajeComplementoMixtaVisual}">

                                <Label
                                    Text="{Binding Source={x:Reference DetallePageRoot}, Path=MensajeComplementoMixtaVisual}"
                                    FontSize="13"
                                    TextColor="#9A3412"
                                    LineBreakMode="WordWrap" />

                            </Border>


                        </VerticalStackLayout>

                    </VerticalStackLayout>

                    <!-- SIN CÁLCULOS -->
                    <Border
                        x:Name="SinCalculosCard"
                        IsVisible="False"
                        BackgroundColor="#F9FAFB"
                        Stroke="#E5E7EB"
                        StrokeShape="RoundRectangle 16"
                        Padding="16">

                        <VerticalStackLayout Spacing="5">

                            <Label
                                Text="Sin cálculos complementarios"
                                FontSize="17"
                                FontAttributes="Bold"
                                TextColor="{StaticResource color_GrisOscuro}" />

                            <Label
                                Text="Este análisis conserva únicamente el requerimiento anual."
                                FontSize="13"
                                TextColor="{StaticResource color_GrisOscuro}" />

                        </VerticalStackLayout>

                    </Border>

                </VerticalStackLayout>

                <BoxView
                    HeightRequest="12"
                    Color="Transparent" />

            </VerticalStackLayout>

        </ScrollView>

        <!-- ACCIONES DE REPORTE -->
        <Border
            Grid.Row="1"
            BackgroundColor="White"
            Stroke="#E5E7EB"
            Padding="14,10">

            <VerticalStackLayout Spacing="8">

                <Grid
                    ColumnDefinitions="*,*"
                    RowDefinitions="Auto,Auto,Auto"
                    ColumnSpacing="8"
                    RowSpacing="8">

                    <Button
                        Grid.Row="0"
                        Grid.Column="0"
                        Text="Guardar PDF"
                        Command="{Binding GuardarPdfCommand}"
                        BackgroundColor="{StaticResource color_Verde}"
                        TextColor="White"
                        CornerRadius="12"
                        Padding="10,9" />

                    <Button
                        Grid.Row="0"
                        Grid.Column="1"
                        Text="Guardar Excel"
                        Command="{Binding GuardarExcelCommand}"
                        BackgroundColor="{StaticResource color_Cafe}"
                        TextColor="White"
                        CornerRadius="12"
                        Padding="10,9" />

                    <Button
                        Grid.Row="1"
                        Grid.Column="0"
                        Text="Compartir PDF"
                        Command="{Binding CompartirPdfCommand}"
                        BackgroundColor="#2563EB"
                        TextColor="White"
                        CornerRadius="12"
                        Padding="10,9" />

                    <Button
                        Grid.Row="1"
                        Grid.Column="1"
                        Text="Compartir Excel"
                        Command="{Binding CompartirExcelCommand}"
                        BackgroundColor="#0F766E"
                        TextColor="White"
                        CornerRadius="12"
                        Padding="10,9" />

                    <Button
                        Grid.Row="2"
                        Grid.ColumnSpan="2"
                        Text="Abrir / imprimir PDF"
                        Command="{Binding ImprimirPdfCommand}"
                        BackgroundColor="{StaticResource BlueUpdate}"
                        TextColor="White"
                        CornerRadius="12"
                        Padding="10,9" />

                </Grid>

                <Button
                    Text="Volver al inicio"
                    Command="{Binding VolverCommand}"
                    Style="{StaticResource CancelButton}" />

            </VerticalStackLayout>

        </Border>

        <!-- CARGA -->
        <Grid
            Grid.RowSpan="2"
            BackgroundColor="#80000000"
            IsVisible="{Binding IsBusy}">

            <VerticalStackLayout
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Spacing="12">

                <ActivityIndicator
                    IsRunning="{Binding IsBusy}"
                    Color="White"
                    WidthRequest="42"
                    HeightRequest="42" />

                <Label
                    Text="Procesando..."
                    TextColor="White"
                    FontAttributes="Bold" />

            </VerticalStackLayout>

        </Grid>

    </Grid>

</ContentPage>
