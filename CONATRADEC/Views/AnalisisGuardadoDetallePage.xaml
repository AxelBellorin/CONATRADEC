<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CONATRADEC.Views.AnalisisGuardadoDetallePage"
    x:Name="DetallePageRoot"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:converters="clr-namespace:CONATRADEC.Converters"
    xmlns:viewModels="clr-namespace:CONATRADEC.ViewModels"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource color_Blanco}">

    <ContentPage.Resources>
        <converters:QuintalesCompraConverter
            x:Key="QuintalesCompraConverter" />

        <converters:CostoCompraFuenteConverter
            x:Key="CostoCompraFuenteConverter" />

        <converters:BalanceResumenTotalConverter
            x:Key="BalanceResumenTotalConverter" />

        <converters:ModoBalanceConverter
            x:Key="ModoBalanceConverter" />

        <converters:ModoMixtaConverter
            x:Key="ModoMixtaConverter" />

        <converters:EnmiendaInterpretacionConverter
            x:Key="EnmiendaInterpretacionConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">

            <VerticalStackLayout
                Padding="18,14"
                Spacing="14">

                <!-- ENCABEZADO -->
                <Grid
                    ColumnDefinitions="Auto,*,Auto"
                    ColumnSpacing="10">

                    <Button
                        Grid.Column="0"
                        Text="‹"
                        Command="{Binding VolverCommand}"
                        BackgroundColor="#F3F4F6"
                        TextColor="{StaticResource color_Negro}"
                        FontSize="24"
                        WidthRequest="48"
                        HeightRequest="48"
                        CornerRadius="14" />

                    <VerticalStackLayout
                        Grid.Column="1"
                        Spacing="2"
                        VerticalOptions="Center">

                        <Label
                            Text="Detalle del análisis"
                            FontSize="25"
                            FontAttributes="Bold"
                            TextColor="{StaticResource color_Verde}" />

                        <Label
                            Text="Visualización completa de los datos y cálculos guardados"
                            FontSize="13"
                            TextColor="{StaticResource color_GrisOscuro}"
                            LineBreakMode="WordWrap" />

                    </VerticalStackLayout>

                    <Button
                        x:Name="EditarButton"
                        Grid.Column="2"
                        Text="Editar"
                        IsVisible="{Binding CanEdit}"
                        BackgroundColor="{StaticResource BlueUpdate}"
                        TextColor="White"
                        CornerRadius="12"
                        Padding="14,8" />

                </Grid>

                <!-- MENSAJES -->
                <Border
                    IsVisible="{Binding TieneMensaje}"
                    BackgroundColor="#FFF7ED"
                    Stroke="#FED7AA"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 14"
                    Padding="12">

                    <Label
                        Text="{Binding Mensaje}"
                        FontSize="13"
                        TextColor="#9A3412"
                        LineBreakMode="WordWrap" />

                </Border>

                <VerticalStackLayout
                    IsVisible="{Binding TieneDetalle}"
                    Spacing="14">

                    <!-- DATOS GENERALES -->
                    <Border
                        Style="{StaticResource CardAnalisisStyle}">

                        <VerticalStackLayout Spacing="12">

                            <Label
                                Text="Datos generales"
                                Style="{StaticResource SectionTitleStyle}" />

                            <Label
                                Text="{Binding ClienteMostrar}"
                                FontSize="18"
                                FontAttributes="Bold"
                                TextColor="{StaticResource color_Negro}" />

                            <Label
                                Text="{Binding TerrenoMostrar}"
                                FontSize="13"
                                TextColor="{StaticResource color_GrisOscuro}" />

                            <Grid
                                ColumnDefinitions="*,*"
                                RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                                ColumnSpacing="12"
                                RowSpacing="10">

                                <VerticalStackLayout
                                    Grid.Row="0"
                                    Grid.Column="0">

                                    <Label
                                        Text="Identificador"
                                        FontSize="11"
                                        TextColor="{StaticResource color_GrisOscuro}" />

                                    <Label
                                        Text="{Binding Detalle.DatosAnalisis.IdentificadorAnalisisSuelo}"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource color_Verde}" />

                                </VerticalStackLayout>

                                <VerticalStackLayout
                                    Grid.Row="0"
                                    Grid.Column="1">

                                    <Label
                                        Text="Fecha del análisis"
                                        FontSize="11"
                                        TextColor="{StaticResource color_GrisOscuro}" />

                                    <Label
                                        Text="{Binding Detalle.DatosAnalisis.FechaAnalisisTexto}"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource color_Negro}" />

                                </VerticalStackLayout>

                                <VerticalStackLayout
                                    Grid.Row="1"
                                    Grid.ColumnSpan="2">

                                    <Label
                                        Text="Laboratorio"
                                        FontSize="11"
                                        TextColor="{StaticResource color_GrisOscuro}" />

                                    <Label
                                        Text="{Binding Detalle.DatosAnalisis.LaboratorioAnalasisSuelo}"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource color_Negro}" />

                                </VerticalStackLayout>

                                <VerticalStackLayout
                                    Grid.Row="2"
                                    Grid.ColumnSpan="2">

                                    <Label
                                        Text="Fecha y hora de registro"
                                        FontSize="11"
                                        TextColor="{StaticResource color_GrisOscuro}" />

                                    <Label
                                        Text="{Binding Detalle.DatosAnalisis.FechaRegistroTexto}"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource color_Verde}" />

                                </VerticalStackLayout>

                                <VerticalStackLayout
                                    Grid.Row="3"
                                    Grid.Column="0">

                                    <Label
                                        Text="pH"
                                        FontSize="11"
                                        TextColor="{StaticResource color_GrisOscuro}" />

                                    <Label
                                        Text="{Binding Detalle.RequerimientoAnual.Ph, StringFormat='{0:N2}'}"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource color_Negro}" />

                                </VerticalStackLayout>

                                <VerticalStackLayout
                                    Grid.Row="3"
                                    Grid.Column="1">

                                    <Label
                                        Text="Acidez total"
                                        FontSize="11"
                                        TextColor="{StaticResource color_GrisOscuro}" />

                                    <Label
                                        Text="{Binding Detalle.RequerimientoAnual.AcidezTotal, StringFormat='{0:N2}'}"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource color_Negro}" />

                                </VerticalStackLayout>

                                <VerticalStackLayout
                                    Grid.Row="4"
                                    Grid.Column="0">

                                    <Label
                                        Text="Materia orgánica"
                                        FontSize="11"
                                        TextColor="{StaticResource color_GrisOscuro}" />

                                    <Label
                                        Text="{Binding Detalle.RequerimientoAnual.MateriaOrganica, StringFormat='{0:N2}'}"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource color_Negro}" />

                                </VerticalStackLayout>

                                <VerticalStackLayout
                                    Grid.Row="4"
                                    Grid.Column="1">

                                    <Label
                                        Text="Producción"
                                        FontSize="11"
                                        TextColor="{StaticResource color_GrisOscuro}" />

                                    <Label
                                        Text="{Binding Detalle.RequerimientoAnual.CantidadQuintalesOro, StringFormat='{0:N2} qq oro'}"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource color_Cafe}" />

                                </VerticalStackLayout>

                            </Grid>

                        </VerticalStackLayout>

                    </Border>

                    <!-- VALORES ORIGINALES -->
                    <Border
                        Style="{StaticResource CardAnalisisStyle}">

                        <VerticalStackLayout Spacing="12">

                            <Label
                                Text="Valores originales del laboratorio"
                                Style="{StaticResource SectionTitleStyle}" />

                            <VerticalStackLayout
                                BindableLayout.ItemsSource="{Binding Detalle.DatosAnalisis.ElementosQuimicos}"
                                Spacing="8">

                                <BindableLayout.ItemTemplate>

                                    <DataTemplate>

                                        <Border
                                            BackgroundColor="#F9FAFB"
                                            Stroke="#E5E7EB"
                                            StrokeShape="RoundRectangle 12"
                                            Padding="11">

                                            <Grid
                                                ColumnDefinitions="*,Auto"
                                                ColumnSpacing="10">

                                                <VerticalStackLayout Spacing="2">

                                                    <Label
                                                        Text="{Binding ElementoMostrar}"
                                                        FontAttributes="Bold"
                                                        TextColor="{StaticResource color_Negro}" />

                                                    <Label
                                                        Text="{Binding UnidadMostrar}"
                                                        FontSize="11"
                                                        TextColor="{StaticResource color_GrisOscuro}" />

                                                </VerticalStackLayout>

                                                <Label
                                                    Grid.Column="1"
                                                    Text="{Binding CantidadElemento, StringFormat='{0:N4}'}"
                                                    FontAttributes="Bold"
                                                    TextColor="{StaticResource color_Cafe}"
                                                    VerticalOptions="Center" />

                                            </Grid>

                                        </Border>

                                    </DataTemplate>

                                </BindableLayout.ItemTemplate>

                            </VerticalStackLayout>

                        </VerticalStackLayout>

                    </Border>

                    <!-- REQUERIMIENTO ANUAL -->
                    <Border
                        Style="{StaticResource CardAnalisisStyle}">

                        <VerticalStackLayout Spacing="14">

                            <Label
                                Text="Requerimiento anual"
                                Style="{StaticResource SectionTitleStyle}" />

                            <Grid
                                ColumnDefinitions="*,*"
                                ColumnSpacing="12">

                                <VerticalStackLayout Grid.Column="0">

                                    <Label
                                        Text="Producción"
                                        FontSize="11"
                                        TextColor="{StaticResource color_GrisOscuro}" />

                                    <Label
                                        Text="{Binding Detalle.RequerimientoAnual.CantidadQuintalesOro, StringFormat='{0:N2} qq oro'}"
                                        FontAttributes="Bold" />

                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Column="1">

                                    <Label
                                        Text="Tamaño de finca"
                                        FontSize="11"
                                        TextColor="{StaticResource color_GrisOscuro}" />

                                    <Label
                                        Text="{Binding Detalle.RequerimientoAnual.TamanoFinca, StringFormat='{0:N2} mz'}"
                                        FontAttributes="Bold" />

                                </VerticalStackLayout>

                            </Grid>

                            <VerticalStackLayout
                                BindableLayout.ItemsSource="{Binding Detalle.RequerimientoAnual.Elementos}"
                                Spacing="8">

                                <BindableLayout.ItemTemplate>

                                    <DataTemplate>

                                        <Border
                                            BackgroundColor="#F9FAFB"
                                            Stroke="#E5E7EB"
                                            StrokeShape="RoundRectangle 12"
                                            Padding="11">

                                            <VerticalStackLayout Spacing="7">

                                                <Grid
                                                    ColumnDefinitions="*,Auto"
                                                    ColumnSpacing="10">

                                                    <VerticalStackLayout Spacing="2">

                                                        <Label
                                                            Text="{Binding ElementoMostrar}"
                                                            FontAttributes="Bold"
                                                            TextColor="{StaticResource color_Verde}" />

                                                        <Label
                                                            Text="{Binding Clasificacion}"
                                                            FontSize="11"
                                                            FontAttributes="Bold"
                                                            TextColor="{StaticResource color_Cafe}" />

                                                    </VerticalStackLayout>

                                                    <Label
                                                        Grid.Column="1"
                                                        Text="{Binding RequerimientoCalculado, StringFormat='{0:N2} lb/mz'}"
                                                        FontAttributes="Bold"
                                                        TextColor="{StaticResource color_Cafe}"
                                                        VerticalOptions="Center" />

                                                </Grid>

                                                <Grid
                                                    ColumnDefinitions="*,*"
                                                    ColumnSpacing="10">

                                                    <VerticalStackLayout Grid.Column="0">

                                                        <Label
                                                            Text="Cantidad ingresada"
                                                            FontSize="11"
                                                            TextColor="{StaticResource color_GrisOscuro}" />

                                                        <Label
                                                            Text="{Binding CantidadIngresada, StringFormat='{0:N4}'}"
                                                            FontSize="13"
                                                            FontAttributes="Bold" />

                                                    </VerticalStackLayout>

                                                    <VerticalStackLayout Grid.Column="1">

                                                        <Label
                                                            Text="Cantidad convertida"
                                                            FontSize="11"
                                                            TextColor="{StaticResource color_GrisOscuro}" />

                                                        <Label
                                                            Text="{Binding CantidadConvertidaLbMz, StringFormat='{0:N2} lb/mz'}"
                                                            FontSize="13"
                                                            FontAttributes="Bold" />

                                                    </VerticalStackLayout>

                                                </Grid>

                                                <Label
                                                    Text="{Binding Observacion}"
                                                    FontSize="12"
                                                    TextColor="{StaticResource color_GrisOscuro}"
                                                    LineBreakMode="WordWrap" />

                                            </VerticalStackLayout>

                                        </Border>

                                    </DataTemplate>

                                </BindableLayout.ItemTemplate>

                            </VerticalStackLayout>

                            <Border
                                BackgroundColor="#EEF5F2"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 12"
                                Padding="12">

                                <VerticalStackLayout Spacing="5">

                                    <Label
                                        Text="Recomendación general"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource color_Verde}" />

                                    <Label
                                        Text="{Binding Detalle.RequerimientoAnual.RecomendacionGeneral}"
                                        FontSize="13"
                                        TextColor="{StaticResource color_Negro}"
                                        LineBreakMode="WordWrap" />

                                </VerticalStackLayout>

                            </Border>

                            <VerticalStackLayout
                                BindableLayout.ItemsSource="{Binding Detalle.RequerimientoAnual.Observaciones}"
                                Spacing="6">

                                <BindableLayout.ItemTemplate>

                                    <DataTemplate>

                                        <Border
                                            BackgroundColor="#FFF7ED"
                                            Stroke="#FED7AA"
                                            StrokeShape="RoundRectangle 10"
                                            Padding="9">

                                            <Label
                                                Text="{Binding .}"
                                                FontSize="12"
                                                TextColor="#7C2D12"
                                                LineBreakMode="WordWrap" />

                                        </Border>

                                    </DataTemplate>

                                </BindableLayout.ItemTemplate>

                            </VerticalStackLayout>

                        </VerticalStackLayout>

                    </Border>

                    <!-- CÁLCULOS COMPLEMENTARIOS -->
                    <VerticalStackLayout
                        x:Name="ContenedorCalculos"
                        IsVisible="False"
                        Spacing="14">

                        <Border
                            BackgroundColor="{StaticResource color_Verde}"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 18"
                            Padding="16">

                            <VerticalStackLayout Spacing="5">

                                <Label
                                    Text="Cálculos complementarios"
                                    FontSize="21"
                                    FontAttributes="Bold"
                                    TextColor="White" />

                                <Label
                                    Text="Las pestañas muestran los mismos resultados utilizados durante la creación y edición, en modo solo lectura."
                                    FontSize="13"
                                    TextColor="White"
                                    Opacity="0.9"
                                    LineBreakMode="WordWrap" />

                            </VerticalStackLayout>

                        </Border>

                        <Grid
                            ColumnDefinitions="*,*,*"
                            ColumnSpacing="8">

                            <Button
                                x:Name="BalanceTabButton"
                                Grid.Column="0"
                                Text="Balance"
                                Clicked="BalanceTabButton_Clicked"
                                HeightRequest="48"
                                CornerRadius="14"
                                FontAttributes="Bold"
                                BackgroundColor="#E5E7EB"
                                TextColor="Black" />

                            <Button
                                x:Name="EnmiendaTabButton"
                                Grid.Column="1"
                                Text="Enmienda"
                                Clicked="EnmiendaTabButton_Clicked"
                                HeightRequest="48"
                                CornerRadius="14"
                                FontAttributes="Bold"
                                BackgroundColor="#E5E7EB"
                                TextColor="Black" />

                            <Button
                                x:Name="MixtaTabButton"
                                Grid.Column="2"
                                Text="Mixta"
                                Clicked="MixtaTabButton_Clicked"
                                HeightRequest="48"
                                CornerRadius="14"
                                FontAttributes="Bold"
                                BackgroundColor="#E5E7EB"
                                TextColor="Black" />

                        </Grid>

                        <!-- BALANCE -->
                        <VerticalStackLayout
                            x:Name="BalancePanel"
                            IsVisible="False"
                            Spacing="14">

                            <Border
                                BackgroundColor="White"
                                Stroke="#E5E7EB"
                                StrokeShape="RoundRectangle 16"
                                Padding="16">

                                <VerticalStackLayout Spacing="12">

                                    <Label
                                        Text="Balance de fórmula"
                                        FontSize="21"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource color_Verde}" />

                                    <Label
                                        Text="{Binding Detalle.BalanceNutricional.Formula.NombreFormula}"
                                        FontSize="16"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource color_Negro}" />

                                    <Border
                                        BackgroundColor="#EEF5F2"
                                        Stroke="{StaticResource color_Verde}"
                                        StrokeShape="RoundRectangle 12"
                                        Padding="11">

                                        <Label
                                            Text="{Binding Detalle.BalanceNutricional.Formula.EsComplementoFertilizacionMixta, Converter={StaticResource ModoBalanceConverter}}"
                                            FontSize="13"
                                            FontAttributes="Bold"
                                            TextColor="{StaticResource color_Verde}"
                                            LineBreakMode="WordWrap" />

                                    </Border>

                                    <Grid
                                        ColumnDefinitions="*,*"
                                        RowDefinitions="Auto,Auto,Auto"
                                        ColumnSpacing="12"
                                        RowSpacing="10">

                                        <VerticalStackLayout
                                            Grid.Row="0"
                                            Grid.Column="0">

                                            <Label
                                                Text="Total de plantas"
                                                FontSize="11"
                                                TextColor="{StaticResource color_GrisOscuro}" />

                                            <Label
                                                Text="{Binding Detalle.BalanceNutricional.Formula.TotalPlantas, StringFormat='{0:N0}'}"
                                                FontAttributes="Bold" />

                                        </VerticalStackLayout>

                                        <VerticalStackLayout
                                            Grid.Row="0"
                                            Grid.Column="1">

                                            <Label
                                                Text="Aplicaciones"
                                                FontSize="11"
                                                TextColor="{StaticResource color_GrisOscuro}" />

                                            <Label
                                                Text="{Binding Detalle.BalanceNutricional.Formula.TotalAplicaciones}"
                                                FontAttributes="Bold" />

                                        </VerticalStackLayout>

                                        <VerticalStackLayout
                                            Grid.Row="1"
                                            Grid.Column="0">

                                            <Label
                                                Text="Total mezcla"
                                                FontSize="11"
                                                TextColor="{StaticResource color_GrisOscuro}" />

                                            <Label
                                                Text="{Binding Detalle.BalanceNutricional.Formula.MezclaTotalQq, StringFormat='{0:N2} qq'}"
                                                FontAttributes="Bold" />

                                        </VerticalStackLayout>

                                        <VerticalStackLayout
                                            Grid.Row="1"
                                            Grid.Column="1">

                                            <Label
                                                Text="Total libras"
                                                FontSize="11"
                                                TextColor="{StaticResource color_GrisOscuro}" />

                                            <Label
                                                Text="{Binding Detalle.BalanceNutricional.Formula.TotalLibras, StringFormat='{0:N2} lb'}"
                                                FontAttributes="Bold" />

                                        </VerticalStackLayout>

                                        <VerticalStackLayout
                                            Grid.Row="2"
                                            Grid.Column="0">

                                            <Label
                                                Text="Dosis anual por planta"
                                                FontSize="11"
                                                TextColor="{StaticResource color_GrisOscuro}" />

                                            <Label
                                                Text="{Binding Detalle.BalanceNutricional.Formula.DosisPlantaAnualOz, StringFormat='{0:N4} oz'}"
                                                FontAttributes="Bold" />

                                        </VerticalStackLayout>

                                        <VerticalStackLayout
                                            Grid.Row="2"
                                            Grid.Column="1">

                                            <Label
                                                Text="Dosis por aplicación"
                                                FontSize="11"
                                                TextColor="{StaticResource color_GrisOscuro}" />

                                            <Label
                                                Text="{Binding Detalle.BalanceNutricional.Formula.DosisPlantaPorAplicacionOz, StringFormat='{0:N4} oz'}"
                                                FontAttributes="Bold" />

                                        </VerticalStackLayout>

                                    </Grid>

                                </VerticalStackLayout>

                            </Border>

                            <!-- CUADRO DE FÓRMULA -->
                            <Border
                                BackgroundColor="White"
                                Stroke="#E5E7EB"
                                StrokeShape="RoundRectangle 16"
                                Padding="16">

                                <VerticalStackLayout Spacing="12">

                                    <Label
                                        Text="Cuadro de fórmula"
                                        FontSize="18"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource color_Verde}" />

                                    <Label
                                        Text="Deslice horizontalmente para consultar todas las cantidades guardadas."
                                        FontSize="12"
                                        TextColor="{StaticResource color_GrisOscuro}" />

                                    <ScrollView Orientation="Horizontal">

                                        <VerticalStackLayout Spacing="0">

                                            <Grid
                                                ColumnDefinitions="180,110,95,145,120,120,120,120"
                                                BackgroundColor="{StaticResource color_Verde}"
                                                MinimumWidthRequest="1010">

                                                <Label Grid.Column="0" Text="Fuente / elemento" TextColor="White" FontAttributes="Bold" Padding="8" />
                                                <Label Grid.Column="1" Text="Libras" TextColor="White" FontAttributes="Bold" Padding="8" HorizontalTextAlignment="End" />
                                                <Label Grid.Column="2" Text="QQ" TextColor="White" FontAttributes="Bold" Padding="8" HorizontalTextAlignment="End" />
                                                <Label Grid.Column="3" Text="Requerimiento" TextColor="White" FontAttributes="Bold" Padding="8" HorizontalTextAlignment="End" />
                                                <Label Grid.Column="4" Text="Precio/QQ" TextColor="White" FontAttributes="Bold" Padding="8" HorizontalTextAlignment="End" />
                                                <Label Grid.Column="5" Text="Subtotal" TextColor="White" FontAttributes="Bold" Padding="8" HorizontalTextAlignment="End" />
                                                <Label Grid.Column="6" Text="Oz anuales" TextColor="White" FontAttributes="Bold" Padding="8" HorizontalTextAlignment="End" />
                                                <Label Grid.Column="7" Text="Oz/aplicación" TextColor="White" FontAttributes="Bold" Padding="8" HorizontalTextAlignment="End" />

                                            </Grid>

                                            <VerticalStackLayout
                                                Spacing="0"
                                                BindableLayout.ItemsSource="{Binding Detalle.BalanceNutricional.Detalles}">

                                                <BindableLayout.ItemTemplate>

                                                    <DataTemplate>

                                                        <Grid
                                                            ColumnDefinitions="180,110,95,145,120,120,120,120"
                                                            MinimumWidthRequest="1010"
                                                            BackgroundColor="#F9FAFB">

                                                            <VerticalStackLayout Grid.Column="0" Padding="8,6" Spacing="1">
                                                                <Label Text="{Binding FuenteMostrar}" FontSize="12" FontAttributes="Bold" />
                                                                <Label Text="{Binding ElementoMostrar}" FontSize="11" TextColor="{StaticResource color_GrisOscuro}" />
                                                            </VerticalStackLayout>

                                                            <Label Grid.Column="1" Text="{Binding Libras, StringFormat='{0:N2}'}" Padding="8,6" HorizontalTextAlignment="End" />
                                                            <Label Grid.Column="2" Text="{Binding Qq, StringFormat='{0:N2}'}" Padding="8,6" HorizontalTextAlignment="End" />
                                                            <Label Grid.Column="3" Text="{Binding RequerimientoLibras, StringFormat='{0:N2} lb'}" Padding="8,6" HorizontalTextAlignment="End" />
                                                            <Label Grid.Column="4" Text="{Binding PrecioPorQuintal, StringFormat='C$ {0:N2}'}" Padding="8,6" HorizontalTextAlignment="End" />
                                                            <Label Grid.Column="5" Text="{Binding SubtotalFuente, StringFormat='C$ {0:N2}'}" Padding="8,6" HorizontalTextAlignment="End" FontAttributes="Bold" />
                                                            <Label Grid.Column="6" Text="{Binding OnzasAnuales, StringFormat='{0:N2}'}" Padding="8,6" HorizontalTextAlignment="End" />
                                                            <Label Grid.Column="7" Text="{Binding OnzasPorAplicacion, StringFormat='{0:N2}'}" Padding="8,6" HorizontalTextAlignment="End" />

                                                        </Grid>

                                                    </DataTemplate>

                                                </BindableLayout.ItemTemplate>

                                            </VerticalStackLayout>

                                        </VerticalStackLayout>

                                    </ScrollView>

                                </VerticalStackLayout>

                            </Border>

                            <!-- COSTOS -->
                            <Border
                                BackgroundColor="White"
                                Stroke="#E5E7EB"
                                StrokeShape="RoundRectangle 16"
                                Padding="16">

                                <VerticalStackLayout Spacing="12">

                                    <Label
                                        Text="Resumen de costos"
                                        FontSize="18"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource color_Verde}" />

                                    <Label
                                        Text="El costo de compra utiliza quintales enteros; el subtotal exacto se conserva como referencia."
                                        FontSize="12"
                                        TextColor="{StaticResource color_GrisOscuro}"
                                        LineBreakMode="WordWrap" />

                                    <ScrollView Orientation="Horizontal">

                                        <VerticalStackLayout Spacing="0">

                                            <Grid
                                                ColumnDefinitions="180,100,100,115,120,130,135"
                                                MinimumWidthRequest="880"
                                                BackgroundColor="#5F6663">

                                                <Label Grid.Column="0" Text="Fuente" TextColor="White" FontAttributes="Bold" Padding="8" />
                                                <Label Grid.Column="1" Text="Libras" TextColor="White" FontAttributes="Bold" Padding="8" HorizontalTextAlignment="End" />
                                                <Label Grid.Column="2" Text="QQ exactos" TextColor="White" FontAttributes="Bold" Padding="8" HorizontalTextAlignment="End" />
                                                <Label Grid.Column="3" Text="QQ comprar" TextColor="White" FontAttributes="Bold" Padding="8" HorizontalTextAlignment="End" />
                                                <Label Grid.Column="4" Text="Precio/QQ" TextColor="White" FontAttributes="Bold" Padding="8" HorizontalTextAlignment="End" />
                                                <Label Grid.Column="5" Text="Subtotal exacto" TextColor="White" FontAttributes="Bold" Padding="8" HorizontalTextAlignment="End" />
                                                <Label Grid.Column="6" Text="Costo compra" TextColor="White" FontAttributes="Bold" Padding="8" HorizontalTextAlignment="End" />

                                            </Grid>

                                            <VerticalStackLayout
                                                Spacing="0"
                                                BindableLayout.ItemsSource="{Binding Detalle.BalanceNutricional.Detalles}">

                                                <BindableLayout.ItemTemplate>

                                                    <DataTemplate>

                                                        <Grid
                                                            ColumnDefinitions="180,100,100,115,120,130,135"
                                                            MinimumWidthRequest="880"
                                                            BackgroundColor="#EEF5F2">

                                                            <Label Grid.Column="0" Text="{Binding FuenteMostrar}" Padding="8,6" FontSize="12" FontAttributes="Bold" />
                                                            <Label Grid.Column="1" Text="{Binding Libras, StringFormat='{0:N2}'}" Padding="8,6" HorizontalTextAlignment="End" />
