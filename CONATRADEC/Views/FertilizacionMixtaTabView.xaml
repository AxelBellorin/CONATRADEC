<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="CONATRADEC.Views.FertilizacionMixtaTabView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Grid>

        <VerticalStackLayout Spacing="16">

            <!-- ENCABEZADO -->
            <Border
                BackgroundColor="White"
                Stroke="#E5E7EB"
                Padding="16"
                StrokeShape="RoundRectangle 16">

                <VerticalStackLayout Spacing="10">

                    <Label
                        Text="Fertilización mixta"
                        FontSize="21"
                        FontAttributes="Bold"
                        TextColor="#B08900" />

                    <Border
                        BackgroundColor="#FFFBEB"
                        Stroke="#F2C94C"
                        Padding="12"
                        StrokeShape="RoundRectangle 12">

                        <VerticalStackLayout Spacing="4">

                            <Label
                                Text="{Binding TituloModoCalculo}"
                                FontSize="14"
                                FontAttributes="Bold"
                                TextColor="#92400E" />

                            <Label
                                Text="{Binding DescripcionModoCalculo}"
                                FontSize="13"
                                TextColor="#92400E"
                                LineBreakMode="WordWrap" />

                        </VerticalStackLayout>

                    </Border>

                    <Border
                        BackgroundColor="#EEF5F2"
                        Stroke="#D1FAE5"
                        Padding="12"
                        StrokeShape="RoundRectangle 12">

                        <Label
                            Text="{Binding Mensaje}"
                            FontSize="13"
                            TextColor="{StaticResource color_Verde}"
                            LineBreakMode="WordWrap" />

                    </Border>

                </VerticalStackLayout>

            </Border>

            <!-- REQUERIMIENTOS -->
            <Border
                BackgroundColor="White"
                Stroke="#E5E7EB"
                Padding="16"
                StrokeShape="RoundRectangle 16">

                <VerticalStackLayout Spacing="12">

                    <VerticalStackLayout Spacing="4">

                        <Label
                            Text="Requerimientos utilizados"
                            FontSize="18"
                            FontAttributes="Bold"
                            TextColor="{StaticResource color_Verde}" />

                        <Label
                            Text="En modo complementario corresponden al balance original; en modo independiente provienen del análisis de suelo."
                            FontSize="13"
                            TextColor="{StaticResource color_GrisOscuro}"
                            LineBreakMode="WordWrap" />

                    </VerticalStackLayout>

                    <Label
                        Text="{Binding ErrorElementos}"
                        IsVisible="{Binding TieneErrorElementos}"
                        TextColor="{StaticResource RedDelete}"
                        FontSize="13"
                        FontAttributes="Bold" />

                    <VerticalStackLayout
                        Spacing="8"
                        BindableLayout.ItemsSource="{Binding ElementosExportables}">

                        <BindableLayout.ItemTemplate>
                            <DataTemplate>

                                <Border
                                    BackgroundColor="#F9FAFB"
                                    Stroke="#E5E7EB"
                                    StrokeShape="RoundRectangle 12"
                                    Padding="12">

                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">

                                        <Label
                                            Grid.Column="0"
                                            Text="{Binding ElementoMostrar}"
                                            FontSize="14"
                                            FontAttributes="Bold"
                                            TextColor="{StaticResource color_Negro}"
                                            VerticalOptions="Center" />

                                        <Label
                                            Grid.Column="1"
                                            Text="{Binding ExportableTexto, StringFormat='{0} lb'}"
                                            FontSize="15"
                                            FontAttributes="Bold"
                                            TextColor="{StaticResource color_Cafe}"
                                            VerticalOptions="Center" />

                                    </Grid>

                                </Border>

                            </DataTemplate>
                        </BindableLayout.ItemTemplate>

                    </VerticalStackLayout>

                </VerticalStackLayout>

            </Border>

            <!-- FUENTES ORGÁNICAS -->
            <Border
                BackgroundColor="White"
                Stroke="#E5E7EB"
                Padding="16"
                StrokeShape="RoundRectangle 16">

                <VerticalStackLayout Spacing="14">

                    <VerticalStackLayout Spacing="4">

                        <Label
                            Text="Fuentes orgánicas"
                            FontSize="18"
                            FontAttributes="Bold"
                            TextColor="{StaticResource color_Verde}" />

                        <Label
                            Text="Seleccione las fuentes e ingrese la cantidad exacta que aplicará en quintales."
                            FontSize="13"
                            TextColor="{StaticResource color_GrisOscuro}"
                            LineBreakMode="WordWrap" />

                    </VerticalStackLayout>

                    <Label
                        Text="{Binding ErrorFuentes}"
                        IsVisible="{Binding TieneErrorFuentes}"
                        TextColor="{StaticResource RedDelete}"
                        FontSize="13"
                        FontAttributes="Bold" />

                    <VerticalStackLayout
                        Spacing="10"
                        BindableLayout.ItemsSource="{Binding FuentesDisponibles}">

                        <BindableLayout.ItemTemplate>
                            <DataTemplate>

                                <Border
                                    BackgroundColor="#F9FAFB"
                                    Stroke="#E5E7EB"
                                    StrokeShape="RoundRectangle 14"
                                    Padding="12">

                                    <VerticalStackLayout Spacing="10">

                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">

                                            <CheckBox
                                                Grid.Column="0"
                                                IsChecked="{Binding EstaSeleccionada, Mode=TwoWay}"
                                                Color="{StaticResource color_Verde}"
                                                VerticalOptions="Start" />

                                            <VerticalStackLayout Grid.Column="1" Spacing="3">

                                                <Label
                                                    Text="{Binding NombreFuente}"
                                                    FontSize="16"
                                                    FontAttributes="Bold"
                                                    TextColor="{StaticResource color_Negro}" />

                                                <Label
                                                    Text="{Binding DescripcionFuente}"
                                                    FontSize="13"
                                                    TextColor="{StaticResource color_GrisOscuro}"
                                                    LineBreakMode="WordWrap" />

                                                <Label
                                                    Text="{Binding ElementosTexto}"
                                                    FontSize="12"
                                                    FontAttributes="Bold"
                                                    TextColor="{StaticResource color_Cafe}"
                                                    LineBreakMode="WordWrap" />

                                                <Label
                                                    Text="{Binding TextoPrecioFuente}"
                                                    FontSize="12"
                                                    FontAttributes="Bold"
                                                    TextColor="{StaticResource color_Verde}" />

                                            </VerticalStackLayout>

                                        </Grid>

                                        <VerticalStackLayout Spacing="6">

                                            <Label
                                                Text="Cantidad a aplicar (QQ)"
                                                Style="{StaticResource FieldLabelStyle}" />

                                            <Border Style="{StaticResource InputContainerStyle}">
                                                <Entry
                                                    Text="{Binding CantidadQq, Mode=TwoWay}"
                                                    Placeholder="Ejemplo: 8.00"
                                                    Keyboard="Numeric"
                                                    IsEnabled="{Binding EstaSeleccionada}"
                                                    Style="{StaticResource InputEntryStyle}" />
                                            </Border>

                                            <Label
                                                Text="{Binding ErrorCantidad}"
                                                IsVisible="{Binding TieneErrorCantidad}"
                                                TextColor="{StaticResource RedDelete}"
                                                FontSize="12"
                                                FontAttributes="Bold" />

                                        </VerticalStackLayout>

                                    </VerticalStackLayout>

                                </Border>

                            </DataTemplate>
                        </BindableLayout.ItemTemplate>

                    </VerticalStackLayout>

                </VerticalStackLayout>

            </Border>

            <!-- ACCIONES -->
            <Border
                BackgroundColor="White"
                Stroke="#E5E7EB"
                Padding="16"
                StrokeShape="RoundRectangle 16">

                <VerticalStackLayout Spacing="14">

                    <VerticalStackLayout Spacing="6">

                        <Label
                            Text="Análisis de suelo"
                            Style="{StaticResource FieldLabelStyle}" />

                        <Border Style="{StaticResource InputContainerStyle}">
                            <Label
                                Text="{Binding Observacion}"
                                FontSize="14"
                                TextColor="{StaticResource color_Negro}"
                                VerticalOptions="Center"
                                LineBreakMode="TailTruncation" />
                        </Border>

                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">

                        <Button
                            Grid.Column="0"
                            Text="Reiniciar"
                            Command="{Binding ReiniciarCommand}"
                            Style="{StaticResource CancelButton}" />

                        <Button
                            Grid.Column="1"
                            Text="Calcular"
                            Command="{Binding CalcularCommand}"
                            Style="{StaticResource AddButton}"
                            IsEnabled="{Binding PuedeCalcular}" />

                    </Grid>

                </VerticalStackLayout>

            </Border>

            <!-- RESUMEN NUTRICIONAL -->
            <Border
                BackgroundColor="White"
                Stroke="#E5E7EB"
                Padding="16"
                StrokeShape="RoundRectangle 16"
                IsVisible="{Binding TieneResultadoFertilizacionMixta}">

                <VerticalStackLayout Spacing="14">

                    <VerticalStackLayout Spacing="4">

                        <Label
                            Text="Resumen de aportes orgánicos"
                            FontSize="18"
                            FontAttributes="Bold"
                            TextColor="{StaticResource color_Verde}" />

                        <Label
                            Text="Deslice horizontalmente para consultar todas las columnas. El sobrante se informa y no impide continuar."
                            FontSize="13"
                            TextColor="{StaticResource color_GrisOscuro}"
                            LineBreakMode="WordWrap" />

                    </VerticalStackLayout>

                    <ScrollView Orientation="Horizontal">

                        <VerticalStackLayout Spacing="0">

                            <Grid
                                MinimumWidthRequest="{OnIdiom Phone=940, Tablet=1030, Desktop=1640}"
                                HorizontalOptions="Fill"
                                BackgroundColor="{StaticResource color_Verde}"
                                Padding="0">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="{OnIdiom Phone=110, Tablet=120, Desktop=190}" />
                                    <ColumnDefinition Width="{OnIdiom Phone=175, Tablet=190, Desktop=300}" />
                                    <ColumnDefinition Width="{OnIdiom Phone=190, Tablet=210, Desktop=320}" />
                                    <ColumnDefinition Width="{OnIdiom Phone=155, Tablet=170, Desktop=270}" />
                                    <ColumnDefinition Width="{OnIdiom Phone=155, Tablet=170, Desktop=280}" />
                                    <ColumnDefinition Width="{OnIdiom Phone=155, Tablet=170, Desktop=280}" />
                                </Grid.ColumnDefinitions>

                                <Label Grid.Column="0" Text="Elemento" Style="{StaticResource FieldLabelStyle}" TextColor="White" Padding="10" LineBreakMode="NoWrap" />
                                <Label Grid.Column="1" Text="Requerimiento (lb)" Style="{StaticResource FieldLabelStyle}" TextColor="White" Padding="10" HorizontalTextAlignment="End" LineBreakMode="NoWrap" />
                                <Label Grid.Column="2" Text="Aporte orgánico (lb)" Style="{StaticResource FieldLabelStyle}" TextColor="White" Padding="10" HorizontalTextAlignment="End" LineBreakMode="NoWrap" />
                                <Label Grid.Column="3" Text="Diferencia (lb)" Style="{StaticResource FieldLabelStyle}" TextColor="White" Padding="10" HorizontalTextAlignment="End" LineBreakMode="NoWrap" />
                                <Label Grid.Column="4" Text="Restante (lb)" Style="{StaticResource FieldLabelStyle}" TextColor="White" Padding="10" HorizontalTextAlignment="End" LineBreakMode="NoWrap" />
                                <Label Grid.Column="5" Text="Sobrante (lb)" Style="{StaticResource FieldLabelStyle}" TextColor="White" Padding="10" HorizontalTextAlignment="End" LineBreakMode="NoWrap" />

                            </Grid>

                            <VerticalStackLayout
                                Spacing="0"
                                BindableLayout.ItemsSource="{Binding ResultadoFertilizacionMixta.Detalles}">

                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>

                                        <Grid
                                            MinimumWidthRequest="{OnIdiom Phone=940, Tablet=1030, Desktop=1640}"
                                            HorizontalOptions="Fill"
                                            BackgroundColor="#F9FAFB">

                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="{OnIdiom Phone=110, Tablet=120, Desktop=190}" />
                                                <ColumnDefinition Width="{OnIdiom Phone=175, Tablet=190, Desktop=300}" />
                                                <ColumnDefinition Width="{OnIdiom Phone=190, Tablet=210, Desktop=320}" />
                                                <ColumnDefinition Width="{OnIdiom Phone=155, Tablet=170, Desktop=270}" />
                                                <ColumnDefinition Width="{OnIdiom Phone=155, Tablet=170, Desktop=280}" />
                                                <ColumnDefinition Width="{OnIdiom Phone=155, Tablet=170, Desktop=280}" />
                                            </Grid.ColumnDefinitions>

                                            <Label Grid.Column="0" Text="{Binding Elemento}" FontAttributes="Bold" TextColor="{StaticResource color_Negro}" Padding="8" />
                                            <Label Grid.Column="1" Text="{Binding Exportable, StringFormat='{0:N2}'}" HorizontalTextAlignment="End" TextColor="{StaticResource color_GrisOscuro}" Padding="8" />
                                            <Label Grid.Column="2" Text="{Binding AporteOrganico, StringFormat='{0:N2}'}" HorizontalTextAlignment="End" TextColor="{StaticResource color_GrisOscuro}" Padding="8" />
                                            <Label Grid.Column="3" Text="{Binding Diferencia, StringFormat='{0:N2}'}" HorizontalTextAlignment="End" TextColor="{StaticResource color_Cafe}" Padding="8" />
                                            <Label Grid.Column="4" Text="{Binding Deficit, StringFormat='{0:N2}'}" HorizontalTextAlignment="End" FontAttributes="Bold" TextColor="{StaticResource RedDelete}" Padding="8" />
                                            <Label Grid.Column="5" Text="{Binding Sobrante, StringFormat='{0:N2}'}" HorizontalTextAlignment="End" FontAttributes="Bold" TextColor="{StaticResource color_Verde}" Padding="8" />

                                        </Grid>

                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>

                            </VerticalStackLayout>

                        </VerticalStackLayout>

                    </ScrollView>

                </VerticalStackLayout>

            </Border>

            <!-- MATRIZ DINÁMICA DE APORTES POR FUENTE -->
            <Border
                BackgroundColor="White"
                Stroke="#E5E7EB"
                Padding="16"
                StrokeShape="RoundRectangle 16"
                IsVisible="{Binding TieneMatrizAportes}">

                <VerticalStackLayout Spacing="14">

                    <VerticalStackLayout Spacing="4">

                        <Label
                            Text="Aportes por fuente"
                            FontSize="18"
                            FontAttributes="Bold"
                            TextColor="{StaticResource color_Verde}" />

                        <Label
                            Text="La cantidad aplicada se presenta en quintales y el aporte total de cada elemento en libras."
                            FontSize="13"
                            TextColor="{StaticResource color_GrisOscuro}"
                            LineBreakMode="WordWrap" />

                    </VerticalStackLayout>

                    <ScrollView Orientation="Horizontal">

                        <VerticalStackLayout Spacing="0">

                            <!-- ENCABEZADO DINÁMICO -->
                            <HorizontalStackLayout Spacing="0">

                                <Border
                                    WidthRequest="{OnIdiom Phone=160, Tablet=190, Desktop=300}"
                                    BackgroundColor="{StaticResource color_Verde}"
                                    Stroke="White"
                                    StrokeThickness="0.5"
                                    Padding="10">
                                    <Label Text="Fuente" FontAttributes="Bold" TextColor="White" LineBreakMode="NoWrap" />
                                </Border>

                                <Border
                                    WidthRequest="{OnIdiom Phone=125, Tablet=140, Desktop=180}"
                                    BackgroundColor="{StaticResource color_Verde}"
                                    Stroke="White"
                                    StrokeThickness="0.5"
                                    Padding="10">
                                    <Label Text="Cantidad (QQ)" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="End" LineBreakMode="NoWrap" />
                                </Border>

                                <HorizontalStackLayout
                                    Spacing="0"
                                    BindableLayout.ItemsSource="{Binding EncabezadosAporteMatriz}">

                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate>
                                            <Border
                                                WidthRequest="{OnIdiom Phone=110, Tablet=145, Desktop=210}"
                                                BackgroundColor="{StaticResource color_Verde}"
                                                Stroke="White"
                                                StrokeThickness="0.5"
                                                Padding="10">
                                                <Label Text="{Binding Titulo}" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="End" LineBreakMode="NoWrap" />
                                            </Border>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>

                                </HorizontalStackLayout>

                            </HorizontalStackLayout>

                            <!-- FILAS DINÁMICAS -->
                            <VerticalStackLayout
                                Spacing="0"
                                BindableLayout.ItemsSource="{Binding FilasAporteMatriz}">

                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>

                                        <HorizontalStackLayout Spacing="0">

                                            <Border
                                                WidthRequest="{OnIdiom Phone=160, Tablet=190, Desktop=300}"
                                                BackgroundColor="#F9FAFB"
                                                Stroke="#E5E7EB"
                                                StrokeThickness="0.5"
                                                Padding="10">
                                                <Label Text="{Binding Fuente}" FontAttributes="Bold" TextColor="{StaticResource color_Negro}" LineBreakMode="NoWrap" />
                                            </Border>

                                            <Border
                                                WidthRequest="{OnIdiom Phone=125, Tablet=140, Desktop=180}"
                                                BackgroundColor="#F9FAFB"
                                                Stroke="#E5E7EB"
                                                StrokeThickness="0.5"
                                                Padding="10">
                                                <Label Text="{Binding TextoCantidadQq}" TextColor="{StaticResource color_Cafe}" FontAttributes="Bold" HorizontalTextAlignment="End" />
                                            </Border>

                                            <HorizontalStackLayout
                                                Spacing="0"
                                                BindableLayout.ItemsSource="{Binding Aportes}">

                                                <BindableLayout.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border
                                                            WidthRequest="{OnIdiom Phone=110, Tablet=145, Desktop=210}"
                                                            BackgroundColor="#F9FAFB"
                                                            Stroke="#E5E7EB"
                                                            StrokeThickness="0.5"
                                                            Padding="10">
                                                            <Label Text="{Binding TextoAporteLibras}" TextColor="{StaticResource color_GrisOscuro}" HorizontalTextAlignment="End" />
                                                        </Border>
                                                    </DataTemplate>
                                                </BindableLayout.ItemTemplate>

                                            </HorizontalStackLayout>

                                        </HorizontalStackLayout>

                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>

                            </VerticalStackLayout>

                        </VerticalStackLayout>

                    </ScrollView>

                </VerticalStackLayout>

            </Border>

            <!-- SUGERENCIA APROXIMADA DE INCREMENTO -->
            <Border
                BackgroundColor="White"
                Stroke="#E5E7EB"
                Padding="16"
                StrokeShape="RoundRectangle 16"
                IsVisible="{Binding TieneSugerenciaIncremento}">

                <VerticalStackLayout Spacing="14">

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Orientación para completar el aporte" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource color_Verde}" />
                        <Label Text="El cálculo es una sugerencia aproximada que prioriza el menor sobrante posible; no garantiza un balance exacto." FontSize="13" TextColor="{StaticResource color_GrisOscuro}" LineBreakMode="WordWrap" />
                    </VerticalStackLayout>

                    <Border BackgroundColor="#FFFBEB" Stroke="#FDE68A" Padding="12" StrokeShape="RoundRectangle 12">
                        <Label Text="{Binding MensajeSugerencia}" FontSize="13" TextColor="#92400E" LineBreakMode="WordWrap" />
                    </Border>

                    <Border
                        BackgroundColor="#FEF2F2"
                        Stroke="#FECACA"
                        Padding="12"
                        StrokeShape="RoundRectangle 12"
                        IsVisible="{Binding TieneElementosNoCubiertos}">
                        <Label
                            Text="{Binding ElementosNoCubiertos, StringFormat='No pueden cubrirse con las fuentes seleccionadas: {0}. Seleccione una fuente que aporte esos elementos.'}"
                            FontSize="13"
                            FontAttributes="Bold"
                            TextColor="{StaticResource RedDelete}"
                            LineBreakMode="WordWrap" />
                    </Border>

                    <ScrollView
                        Orientation="Horizontal"
                        IsVisible="{Binding TieneSugerenciaIncremento}">

                        <VerticalStackLayout Spacing="0">

                            <Grid ColumnDefinitions="210,130,130,145,160" BackgroundColor="{StaticResource color_Verde}">
                                <Label Grid.Column="0" Text="Fuente" FontAttributes="Bold" TextColor="White" Padding="10" LineBreakMode="NoWrap" />
                                <Label Grid.Column="1" Text="Actual (QQ)" FontAttributes="Bold" TextColor="White" Padding="10" HorizontalTextAlignment="End" LineBreakMode="NoWrap" />
                                <Label Grid.Column="2" Text="Incrementar" FontAttributes="Bold" TextColor="White" Padding="10" HorizontalTextAlignment="End" LineBreakMode="NoWrap" />
                                <Label Grid.Column="3" Text="Total sugerido" FontAttributes="Bold" TextColor="White" Padding="10" HorizontalTextAlignment="End" LineBreakMode="NoWrap" />
                                <Label Grid.Column="4" Text="Costo adicional" FontAttributes="Bold" TextColor="White" Padding="10" HorizontalTextAlignment="End" LineBreakMode="NoWrap" />
                            </Grid>

                            <VerticalStackLayout Spacing="0" BindableLayout.ItemsSource="{Binding FilasSugerenciaIncremento}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="210,130,130,145,160" BackgroundColor="#F9FAFB">
                                            <Label Grid.Column="0" Text="{Binding Fuente}" FontAttributes="Bold" TextColor="{StaticResource color_Negro}" Padding="10" />
                                            <Label Grid.Column="1" Text="{Binding TextoCantidadActualQq}" TextColor="{StaticResource color_GrisOscuro}" Padding="10" HorizontalTextAlignment="End" />
                                            <Label Grid.Column="2" Text="{Binding TextoIncrementarQq}" FontAttributes="Bold" TextColor="{StaticResource color_Cafe}" Padding="10" HorizontalTextAlignment="End" />
                                            <Label Grid.Column="3" Text="{Binding TextoTotalSugeridoQq}" FontAttributes="Bold" TextColor="{StaticResource color_Verde}" Padding="10" HorizontalTextAlignment="End" />
                                            <Label Grid.Column="4" Text="{Binding TextoCostoAdicional}" FontAttributes="Bold" TextColor="{StaticResource color_Cafe}" Padding="10" HorizontalTextAlignment="End" />
                                        </Grid>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>

                        </VerticalStackLayout>

                    </ScrollView>

                    <Button
                        Text="Aplicar sugerencia"
                        Command="{Binding AplicarSugerenciaCommand}"
                        IsEnabled="{Binding PuedeAplicarSugerencia}"
                        IsVisible="{Binding TieneSugerenciaIncremento}"
                        Style="{StaticResource AddButton}"
                        HorizontalOptions="End"
                        MinimumWidthRequest="190" />

                </VerticalStackLayout>

            </Border>

            <!-- OPCIÓN PARA RESTAURAR LAS CANTIDADES ANTERIORES -->
            <Border
                BackgroundColor="#EEF5F2"
                Stroke="#D1FAE5"
                Padding="14"
                StrokeShape="RoundRectangle 14"
                IsVisible="{Binding PuedeDeshacerSugerencia}">

                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">

                    <VerticalStackLayout Grid.Column="0" Spacing="3" VerticalOptions="Center">
                        <Label Text="Se aplicó una sugerencia" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource color_Verde}" />
                        <Label Text="Puede regresar a las cantidades que tenía antes de aplicarla." FontSize="12" TextColor="{StaticResource color_GrisOscuro}" LineBreakMode="WordWrap" />
                    </VerticalStackLayout>

                    <Button
                        Grid.Column="1"
                        Text="Deshacer sugerencia"
                        Command="{Binding DeshacerSugerenciaCommand}"
                        Style="{StaticResource CancelButton}"
                        VerticalOptions="Center"
                        MinimumWidthRequest="180" />

                </Grid>

            </Border>

            <!-- AVISO COMPACTO CUANDO NO HAY INCREMENTO POSIBLE -->
            <Border
                BackgroundColor="#FEF2F2"
                Stroke="#FECACA"
                Padding="12"
                StrokeShape="RoundRectangle 12"
                IsVisible="{Binding MostrarAvisoElementosNoCubiertosSinSugerencia}">

                <Label
                    Text="{Binding ElementosNoCubiertos, StringFormat='No pueden cubrirse con las fuentes seleccionadas: {0}. Seleccione una fuente que aporte esos elementos.'}"
                    FontSize="13"
                    FontAttributes="Bold"
                    TextColor="{StaticResource RedDelete}"
                    LineBreakMode="WordWrap" />

            </Border>

            <!-- COSTOS ORGÁNICOS -->
            <Border
                BackgroundColor="White"
                Stroke="#E5E7EB"
                Padding="16"
                StrokeShape="RoundRectangle 16"
                IsVisible="{Binding TieneTablaCostosOrganicos}">

                <VerticalStackLayout Spacing="14">

                    <Label
                        Text="Costo de fertilización mixta"
                        FontSize="18"
                        FontAttributes="Bold"
                        TextColor="{StaticResource color_Verde}" />

                    <ScrollView Orientation="Horizontal">

                        <VerticalStackLayout Spacing="0">

                            <Grid ColumnDefinitions="200,110,130,140" BackgroundColor="{StaticResource color_Verde}">
                                <Label Grid.Column="0" Text="Fuente orgánica" FontAttributes="Bold" TextColor="White" Padding="8" />
                                <Label Grid.Column="1" Text="Cantidad QQ" FontAttributes="Bold" TextColor="White" Padding="8" HorizontalTextAlignment="End" />
                                <Label Grid.Column="2" Text="Precio/QQ" FontAttributes="Bold" TextColor="White" Padding="8" HorizontalTextAlignment="End" />
                                <Label Grid.Column="3" Text="Costo" FontAttributes="Bold" TextColor="White" Padding="8" HorizontalTextAlignment="End" />
                            </Grid>

                            <VerticalStackLayout Spacing="0" BindableLayout.ItemsSource="{Binding FilasCostoOrganico}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="200,110,130,140" BackgroundColor="#F9FAFB">
                                            <Label Grid.Column="0" Text="{Binding Fuente}" TextColor="{StaticResource color_Negro}" Padding="8" />
                                            <Label Grid.Column="1" Text="{Binding TextoCantidadQq}" TextColor="{StaticResource color_GrisOscuro}" Padding="8" HorizontalTextAlignment="End" />
                                            <Label Grid.Column="2" Text="{Binding TextoPrecioPorQq}" TextColor="{StaticResource color_GrisOscuro}" Padding="8" HorizontalTextAlignment="End" />
                                            <Label Grid.Column="3" Text="{Binding TextoCosto}" FontAttributes="Bold" TextColor="{StaticResource color_Cafe}" Padding="8" HorizontalTextAlignment="End" />
                                        </Grid>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>

                            <Grid ColumnDefinitions="200,110,130,140" BackgroundColor="#EEF5F2">
                                <Label Grid.Column="0" Grid.ColumnSpan="3" Text="Total fertilización mixta" FontAttributes="Bold" TextColor="{StaticResource color_Verde}" Padding="8" />
                                <Label Grid.Column="3" Text="{Binding TextoCostoFertilizacionMixta}" FontAttributes="Bold" TextColor="{StaticResource color_Verde}" Padding="8" HorizontalTextAlignment="End" />
                            </Grid>

                        </VerticalStackLayout>

                    </ScrollView>

                </VerticalStackLayout>

            </Border>

            <!-- COMPRA COMERCIAL AJUSTADA -->
            <Border
                BackgroundColor="White"
                Stroke="#E5E7EB"
                Padding="16"
                StrokeShape="RoundRectangle 16"
                IsVisible="{Binding TieneResultadoBalanceAjustado}">

                <VerticalStackLayout Spacing="14">

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Compra comercial ajustada" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource color_Verde}" />
                        <Label Text="Se mantienen las fuentes del balance original. Las compras con decimales se redondean al siguiente quintal entero." FontSize="13" TextColor="{StaticResource color_GrisOscuro}" LineBreakMode="WordWrap" />
                    </VerticalStackLayout>

                    <ScrollView Orientation="Horizontal">

                        <VerticalStackLayout Spacing="0">

                            <Grid
                                BackgroundColor="{StaticResource color_Verde}"
                                HorizontalOptions="Fill"
                                MinimumWidthRequest="{OnIdiom Phone=1140, Tablet=1300, Desktop=1710}">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="{OnIdiom Phone=220, Tablet=260, Desktop=360}" />
                                    <ColumnDefinition Width="{OnIdiom Phone=115, Tablet=130, Desktop=160}" />
                                    <ColumnDefinition Width="{OnIdiom Phone=135, Tablet=150, Desktop=190}" />
                                    <ColumnDefinition Width="{OnIdiom Phone=135, Tablet=150, Desktop=190}" />
                                    <ColumnDefinition Width="{OnIdiom Phone=125, Tablet=140, Desktop=180}" />
                                    <ColumnDefinition Width="{OnIdiom Phone=145, Tablet=170, Desktop=230}" />
                                    <ColumnDefinition Width="{OnIdiom Phone=110, Tablet=120, Desktop=150}" />
                                    <ColumnDefinition Width="{OnIdiom Phone=155, Tablet=180, Desktop=250}" />
                                </Grid.ColumnDefinitions>

                                <Label Grid.Column="0" Text="Fuente" FontAttributes="Bold" TextColor="White" Padding="8" LineBreakMode="NoWrap" />
                                <Label Grid.Column="1" Text="Elemento" FontAttributes="Bold" TextColor="White" Padding="8" LineBreakMode="NoWrap" />
                                <Label Grid.Column="2" Text="QQ original" FontAttributes="Bold" TextColor="White" Padding="8" HorizontalTextAlignment="End" LineBreakMode="NoWrap" />
                                <Label Grid.Column="3" Text="QQ ajustado" FontAttributes="Bold" TextColor="White" Padding="8" HorizontalTextAlignment="End" LineBreakMode="NoWrap" />
                                <Label Grid.Column="4" Text="Reducción" FontAttributes="Bold" TextColor="White" Padding="8" HorizontalTextAlignment="End" LineBreakMode="NoWrap" />
                                <Label Grid.Column="5" Text="Precio/QQ" FontAttributes="Bold" TextColor="White" Padding="8" HorizontalTextAlignment="End" LineBreakMode="NoWrap" />
                                <Label Grid.Column="6" Text="Comprar" FontAttributes="Bold" TextColor="White" Padding="8" HorizontalTextAlignment="End" LineBreakMode="NoWrap" />
                                <Label Grid.Column="7" Text="Costo compra" FontAttributes="Bold" TextColor="White" Padding="8" HorizontalTextAlignment="End" LineBreakMode="NoWrap" />
                            </Grid>

                            <VerticalStackLayout Spacing="0" BindableLayout.ItemsSource="{Binding FilasCompraAjustada}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <Grid
                                            BackgroundColor="#F9FAFB"
                                            HorizontalOptions="Fill"
                                            MinimumWidthRequest="{OnIdiom Phone=1140, Tablet=1300, Desktop=1710}">

                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="{OnIdiom Phone=220, Tablet=260, Desktop=360}" />
                                                <ColumnDefinition Width="{OnIdiom Phone=115, Tablet=130, Desktop=160}" />
                                                <ColumnDefinition Width="{OnIdiom Phone=135, Tablet=150, Desktop=190}" />
                                                <ColumnDefinition Width="{OnIdiom Phone=135, Tablet=150, Desktop=190}" />
                                                <ColumnDefinition Width="{OnIdiom Phone=125, Tablet=140, Desktop=180}" />
                                                <ColumnDefinition Width="{OnIdiom Phone=145, Tablet=170, Desktop=230}" />
                                                <ColumnDefinition Width="{OnIdiom Phone=110, Tablet=120, Desktop=150}" />
                                                <ColumnDefinition Width="{OnIdiom Phone=155, Tablet=180, Desktop=250}" />
                                            </Grid.ColumnDefinitions>

                                            <Label Grid.Column="0" Text="{Binding Fuente}" TextColor="{StaticResource color_Negro}" Padding="8" />
                                            <Label Grid.Column="1" Text="{Binding Elemento}" FontAttributes="Bold" TextColor="{StaticResource color_Cafe}" Padding="8" LineBreakMode="NoWrap" />
                                            <Label Grid.Column="2" Text="{Binding TextoQuintalesOriginales}" TextColor="{StaticResource color_GrisOscuro}" Padding="8" HorizontalTextAlignment="End" LineBreakMode="NoWrap" />
                                            <Label Grid.Column="3" Text="{Binding TextoQuintalesAjustados}" TextColor="{StaticResource color_GrisOscuro}" Padding="8" HorizontalTextAlignment="End" LineBreakMode="NoWrap" />
                                            <Label Grid.Column="4" Text="{Binding TextoReduccionQuintales}" TextColor="{StaticResource color_Verde}" Padding="8" HorizontalTextAlignment="End" LineBreakMode="NoWrap" />
                                            <Label Grid.Column="5" Text="{Binding TextoPrecioPorQq}" TextColor="{StaticResource color_GrisOscuro}" Padding="8" HorizontalTextAlignment="End" LineBreakMode="NoWrap" />
                                            <Label Grid.Column="6" Text="{Binding TextoQuintalesComprar}" FontAttributes="Bold" TextColor="{StaticResource color_Cafe}" Padding="8" HorizontalTextAlignment="End" LineBreakMode="NoWrap" />
                                            <Label Grid.Column="7" Text="{Binding TextoCostoCompra}" FontAttributes="Bold" TextColor="{StaticResource color_Cafe}" Padding="8" HorizontalTextAlignment="End" LineBreakMode="NoWrap" />
                                        </Grid>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>

                        </VerticalStackLayout>

                    </ScrollView>

                </VerticalStackLayout>

            </Border>

            <!-- SIN COMPRA COMERCIAL -->
            <Border
                BackgroundColor="#EEF5F2"
                Stroke="#D1FAE5"
                Padding="16"
                StrokeShape="RoundRectangle 16"
                IsVisible="{Binding NoRequiereCompraComercial}">

                <Label
                    Text="El aporte orgánico cubre todos los requerimientos seleccionados del balance. No se requiere compra comercial ajustada."
                    FontSize="14"
                    FontAttributes="Bold"
                    TextColor="{StaticResource color_Verde}"
                    LineBreakMode="WordWrap" />

            </Border>

            <!-- RESUMEN ECONÓMICO -->
            <Border
                BackgroundColor="White"
                Stroke="#E5E7EB"
                Padding="16"
                StrokeShape="RoundRectangle 16"
                IsVisible="{Binding ComplementoCalculado}">

                <VerticalStackLayout Spacing="12">

                    <Label
                        Text="Resumen económico"
                        FontSize="18"
                        FontAttributes="Bold"
                        TextColor="{StaticResource color_Verde}" />

                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="10" ColumnSpacing="12">

                        <Label Grid.Row="0" Grid.Column="0" Text="Costo comercial original" TextColor="{StaticResource color_GrisOscuro}" />
                        <Label Grid.Row="0" Grid.Column="1" Text="{Binding TextoCostoComercialOriginal}" FontAttributes="Bold" TextColor="{StaticResource color_Negro}" />

                        <Label Grid.Row="1" Grid.Column="0" Text="Costo fertilización mixta" TextColor="{StaticResource color_GrisOscuro}" />
                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding TextoCostoFertilizacionMixta}" FontAttributes="Bold" TextColor="{StaticResource color_Cafe}" />

                        <Label Grid.Row="2" Grid.Column="0" Text="Costo comercial ajustado" TextColor="{StaticResource color_GrisOscuro}" />
                        <Label Grid.Row="2" Grid.Column="1" Text="{Binding TextoCostoComercialAjustado}" FontAttributes="Bold" TextColor="{StaticResource color_Cafe}" />

                        <Label Grid.Row="3" Grid.Column="0" Text="Costo total final" FontAttributes="Bold" TextColor="{StaticResource color_Negro}" />
                        <Label Grid.Row="3" Grid.Column="1" Text="{Binding TextoCostoTotalFinal}" FontAttributes="Bold" TextColor="{StaticResource color_Negro}" />

                        <Label Grid.Row="4" Grid.Column="0" Text="{Binding EtiquetaDiferenciaEconomica}" FontAttributes="Bold" TextColor="{Binding ColorDiferenciaEconomica}" />
                        <Label Grid.Row="4" Grid.Column="1" Text="{Binding TextoDiferenciaEconomica}" FontAttributes="Bold" TextColor="{Binding ColorDiferenciaEconomica}" />

                    </Grid>

                </VerticalStackLayout>

            </Border>

        </VerticalStackLayout>

        <!-- BUSY -->
        <Grid
            BackgroundColor="#80000000"
            IsVisible="{Binding IsBusy}">

            <VerticalStackLayout
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Spacing="10">

                <ActivityIndicator
                    IsRunning="{Binding IsBusy}"
                    Color="White"
                    WidthRequest="48"
                    HeightRequest="48" />

                <Label
                    Text="Procesando fertilización mixta..."
                    TextColor="White"
                    FontAttributes="Bold"
                    HorizontalTextAlignment="Center" />

            </VerticalStackLayout>

        </Grid>

    </Grid>

</ContentView>
