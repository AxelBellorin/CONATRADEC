<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="CONATRADEC.Views.rangoNutrienteFormPage"
    Shell.NavBarIsVisible="False"
    BackgroundColor="Transparent">

    <Grid
        RowDefinitions="Auto,*"
        Padding="10">

        <Grid
            Grid.Row="0"
            ColumnDefinitions="*,Auto"
            Margin="4,12,4,8">

            <Label
                Text="{Binding Title}"
                FontSize="24"
                FontFamily="MontserratBold"
                TextColor="{StaticResource color_Verde}"
                VerticalOptions="Center" />

            <ActivityIndicator
                Grid.Column="1"
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}"
                Color="{StaticResource color_Naranja}"
                VerticalOptions="Center" />

        </Grid>

        <ScrollView Grid.Row="1">

            <VerticalStackLayout Spacing="15">

                <Border
                    Style="{StaticResource ValidationFieldContainerStyle}">

                    <Border.Triggers>
                        <DataTrigger
                            TargetType="Border"
                            Binding="{Binding TieneErrorTipoCultivo}"
                            Value="True">

                            <Setter
                                Property="Stroke"
                                Value="{StaticResource RedDelete}" />

                            <Setter
                                Property="StrokeThickness"
                                Value="2" />

                        </DataTrigger>
                    </Border.Triggers>

                    <VerticalStackLayout Spacing="5">

                        <Label
                            Text="Tipo de cultivo"
                            FontAttributes="Bold"
                            TextColor="{StaticResource color_Negro}" />

                        <Label
                            Text="{Binding TipoCultivoNombre}"
                            FontSize="17"
                            FontFamily="MontserratMedium"
                            TextColor="{StaticResource color_Verde}"
                            Padding="6,8" />

                        <Label
                            Text="{Binding ErrorTipoCultivo}"
                            IsVisible="{Binding TieneErrorTipoCultivo}"
                            Style="{StaticResource ValidationMessageStyle}" />

                    </VerticalStackLayout>

                </Border>

                <Border
                    Style="{StaticResource ValidationFieldContainerStyle}">

                    <Border.Triggers>
                        <DataTrigger
                            TargetType="Border"
                            Binding="{Binding TieneErrorElemento}"
                            Value="True">

                            <Setter
                                Property="Stroke"
                                Value="{StaticResource RedDelete}" />

                            <Setter
                                Property="StrokeThickness"
                                Value="2" />

                        </DataTrigger>
                    </Border.Triggers>

                    <VerticalStackLayout Spacing="5">

                        <Label
                            Text="Elemento químico"
                            FontAttributes="Bold"
                            TextColor="{StaticResource color_Negro}" />

                        <Picker
                            ItemsSource="{Binding Elementos}"
                            SelectedItem="{Binding ElementoSeleccionado}"
                            ItemDisplayBinding="{Binding Texto}"
                            Title="Seleccione un elemento"
                            IsEnabled="{Binding IsEditable}" />

                        <Label
                            Text="{Binding ErrorElemento}"
                            IsVisible="{Binding TieneErrorElemento}"
                            Style="{StaticResource ValidationMessageStyle}" />

                    </VerticalStackLayout>

                </Border>

                <Grid
                    ColumnDefinitions="*,*"
                    ColumnSpacing="10">

                    <Border
                        Grid.Column="0"
                        Style="{StaticResource ValidationFieldContainerStyle}">

                        <Border.Triggers>
                            <DataTrigger
                                TargetType="Border"
                                Binding="{Binding TieneErrorMinimo}"
                                Value="True">

                                <Setter
                                    Property="Stroke"
                                    Value="{StaticResource RedDelete}" />

                                <Setter
                                    Property="StrokeThickness"
                                    Value="2" />

                            </DataTrigger>
                        </Border.Triggers>

                        <VerticalStackLayout Spacing="5">

                            <Label
                                Text="Valor mínimo"
                                FontAttributes="Bold"
                                TextColor="{StaticResource color_Negro}" />

                            <Entry
                                Text="{Binding MinimoTexto}"
                                Keyboard="Numeric"
                                Style="{StaticResource EntryStyle}"
                                IsReadOnly="{Binding IsReadOnly}" />

                            <Label
                                Text="{Binding ErrorMinimo}"
                                IsVisible="{Binding TieneErrorMinimo}"
                                Style="{StaticResource ValidationMessageStyle}" />

                        </VerticalStackLayout>

                    </Border>

                    <Border
                        Grid.Column="1"
                        Style="{StaticResource ValidationFieldContainerStyle}">

                        <Border.Triggers>
                            <DataTrigger
                                TargetType="Border"
                                Binding="{Binding TieneErrorMaximo}"
                                Value="True">

                                <Setter
                                    Property="Stroke"
                                    Value="{StaticResource RedDelete}" />

                                <Setter
                                    Property="StrokeThickness"
                                    Value="2" />

                            </DataTrigger>
                        </Border.Triggers>

                        <VerticalStackLayout Spacing="5">

                            <Label
                                Text="Valor máximo"
                                FontAttributes="Bold"
                                TextColor="{StaticResource color_Negro}" />

                            <Entry
                                Text="{Binding MaximoTexto}"
                                Keyboard="Numeric"
                                Style="{StaticResource EntryStyle}"
                                IsReadOnly="{Binding IsReadOnly}" />

                            <Label
                                Text="{Binding ErrorMaximo}"
                                IsVisible="{Binding TieneErrorMaximo}"
                                Style="{StaticResource ValidationMessageStyle}" />

                        </VerticalStackLayout>

                    </Border>

                </Grid>

                <Border
                    Style="{StaticResource ValidationFieldContainerStyle}">

                    <VerticalStackLayout Spacing="5">

                        <Label
                            Text="Unidad base"
                            FontAttributes="Bold"
                            TextColor="{StaticResource color_Negro}" />

                        <Label
                            Text="{Binding UnidadBaseDescripcion}"
                            FontSize="16"
                            FontFamily="MontserratMedium"
                            TextColor="{StaticResource color_Verde}"
                            Padding="6,8" />

                        <Label
                            Text="La unidad es fija para todos los rangos."
                            FontSize="12"
                            TextColor="{StaticResource color_Gris}" />

                    </VerticalStackLayout>

                </Border>

                <Border
                    Style="{StaticResource ValidationFieldContainerStyle}">

                    <Border.Triggers>
                        <DataTrigger
                            TargetType="Border"
                            Binding="{Binding TieneErrorDescripcion}"
                            Value="True">

                            <Setter
                                Property="Stroke"
                                Value="{StaticResource RedDelete}" />

                            <Setter
                                Property="StrokeThickness"
                                Value="2" />

                        </DataTrigger>
                    </Border.Triggers>

                    <VerticalStackLayout Spacing="5">

                        <Label
                            Text="Descripción"
                            FontAttributes="Bold"
                            TextColor="{StaticResource color_Negro}" />

                        <Editor
                            Text="{Binding Descripcion}"
                            Placeholder="Descripción del rango de aporte"
                            AutoSize="TextChanges"
                            MinimumHeightRequest="100"
                            IsReadOnly="{Binding IsReadOnly}" />

                        <Label
                            Text="{Binding ErrorDescripcion}"
                            IsVisible="{Binding TieneErrorDescripcion}"
                            Style="{StaticResource ValidationMessageStyle}" />

                    </VerticalStackLayout>

                </Border>

                <Grid
                    ColumnDefinitions="*,*"
                    Margin="6,4">

                    <Button
                        Grid.Column="0"
                        Text="Guardar"
                        Style="{StaticResource UpdateButton}"
                        Command="{Binding SaveCommand}"
                        IsVisible="{Binding ShowSaveButton}"
                        IsEnabled="{Binding NotIsBusy}"
                        Margin="4" />

                    <Button
                        Grid.Column="1"
                        Text="Cancelar"
                        Style="{StaticResource CancelButton}"
                        Command="{Binding CancelCommand}"
                        IsEnabled="{Binding NotIsBusy}"
                        Margin="4" />

                </Grid>

            </VerticalStackLayout>

        </ScrollView>

    </Grid>

</ContentPage>
