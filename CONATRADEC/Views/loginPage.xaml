<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    x:Class="CONATRADEC.Views.loginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#F3F7F5"
    SizeChanged="LoginPage_SizeChanged">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{OnPlatform WinUI='1.08*', Default='0'}" />
            <ColumnDefinition Width="{OnPlatform WinUI='0.92*', Default='*'}" />
        </Grid.ColumnDefinitions>

        <!-- =========================================================
             PANEL INSTITUCIONAL: SOLO WINDOWS
             La mascota ya no ocupa el espacio del logo.
             ========================================================= -->
        <Border
            Grid.Column="0"
            IsVisible="{OnPlatform WinUI=True, Default=False}"
            Margin="24"
            Padding="48"
            BackgroundColor="{StaticResource color_Verde}"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 32">

            <Border.Shadow>
                <Shadow
                    Brush="#233D36"
                    Offset="0,10"
                    Radius="26"
                    Opacity="0.22" />
            </Border.Shadow>

            <Grid RowDefinitions="*,Auto">
                <VerticalStackLayout
                    Grid.Row="0"
                    MaximumWidthRequest="560"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    Spacing="24">

                    <!-- Logo institucional centrado -->
                    <Grid HorizontalOptions="Fill">

                        <Border
                            WidthRequest="138"
                            HeightRequest="138"
                            Padding="8"
                            HorizontalOptions="Center"
                            BackgroundColor="#F7FBF9"
                            Stroke="#D5E4DE"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 36">

                            <Border.Shadow>
                                <Shadow
                                    Brush="#1F352F"
                                    Offset="0,6"
                                    Radius="16"
                                    Opacity="0.16" />
                            </Border.Shadow>

                            <Image
                                Source="logocontradec.png"
                                Aspect="AspectFit" />
                        </Border>

                    </Grid>

                    <VerticalStackLayout Spacing="8">
                        <Label
                            Text="ConatraCafé Soil"
                            FontFamily="MontserratBold"
                            FontSize="46"
                            FontAttributes="Bold"
                            TextColor="White" />

                        <Label
                            Text="Gestión técnica y análisis de suelos para una caficultura más eficiente."
                            MaximumWidthRequest="500"
                            FontFamily="MontserratMedium"
                            FontSize="18"
                            LineHeight="1.25"
                            TextColor="#E5F0EC" />
                    </VerticalStackLayout>

                    <BoxView
                        WidthRequest="72"
                        HeightRequest="4"
                        HorizontalOptions="Start"
                        Color="{StaticResource color_Naranja}"
                        CornerRadius="2" />

                    <VerticalStackLayout Spacing="14">

                        <Grid ColumnDefinitions="42,*" ColumnSpacing="14">
                            <Border
                                Grid.Column="0"
                                WidthRequest="36"
                                HeightRequest="36"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                BackgroundColor="{StaticResource color_Amarillo}"
                                Stroke="#FFF1A6"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 11">

                                <Border.Shadow>
                                    <Shadow
                                        Brush="#1F352F"
                                        Offset="0,3"
                                        Radius="8"
                                        Opacity="0.20" />
                                </Border.Shadow>

                                <Label
                                    Text="✓"
                                    HorizontalOptions="Fill"
                                    VerticalOptions="Fill"
                                    HorizontalTextAlignment="Center"
                                    VerticalTextAlignment="Center"
                                    FontSize="21"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource color_Verde}" />
                            </Border>

                            <Label
                                Grid.Column="1"
                                Text="Consulta y administra análisis de suelo."
                                VerticalOptions="Center"
                                FontFamily="MontserratMedium"
                                FontSize="15"
                                LineBreakMode="WordWrap"
                                TextColor="White" />
                        </Grid>

                        <Grid ColumnDefinitions="42,*" ColumnSpacing="14">
                            <Border
                                Grid.Column="0"
                                WidthRequest="36"
                                HeightRequest="36"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                BackgroundColor="{StaticResource color_Amarillo}"
                                Stroke="#FFF1A6"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 11">

                                <Border.Shadow>
                                    <Shadow
                                        Brush="#1F352F"
                                        Offset="0,3"
                                        Radius="8"
                                        Opacity="0.20" />
                                </Border.Shadow>

                                <Label
                                    Text="✓"
                                    HorizontalOptions="Fill"
                                    VerticalOptions="Fill"
                                    HorizontalTextAlignment="Center"
                                    VerticalTextAlignment="Center"
                                    FontSize="21"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource color_Verde}" />
                            </Border>

                            <Label
                                Grid.Column="1"
                                Text="Obtén recomendaciones nutricionales."
                                VerticalOptions="Center"
                                FontFamily="MontserratMedium"
                                FontSize="15"
                                LineBreakMode="WordWrap"
                                TextColor="White" />
                        </Grid>

                        <Grid ColumnDefinitions="42,*" ColumnSpacing="14">
                            <Border
                                Grid.Column="0"
                                WidthRequest="36"
                                HeightRequest="36"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                BackgroundColor="{StaticResource color_Amarillo}"
                                Stroke="#FFF1A6"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 11">

                                <Border.Shadow>
                                    <Shadow
                                        Brush="#1F352F"
                                        Offset="0,3"
                                        Radius="8"
                                        Opacity="0.20" />
                                </Border.Shadow>

                                <Label
                                    Text="✓"
                                    HorizontalOptions="Fill"
                                    VerticalOptions="Fill"
                                    HorizontalTextAlignment="Center"
                                    VerticalTextAlignment="Center"
                                    FontSize="21"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource color_Verde}" />
                            </Border>

                            <Label
                                Grid.Column="1"
                                Text="Trabaja con una experiencia segura y organizada."
                                VerticalOptions="Center"
                                FontFamily="MontserratMedium"
                                FontSize="15"
                                LineBreakMode="WordWrap"
                                TextColor="White" />
                        </Grid>

                    </VerticalStackLayout>
                </VerticalStackLayout>

                <Label
                    Grid.Row="1"
                    Text="CONATRADEC · Tecnología al servicio del café"
                    FontFamily="MontserratMedium"
                    FontSize="12"
                    TextColor="#D6E6E0" />
            </Grid>
        </Border>

        <!-- =========================================================
             FORMULARIO: WINDOWS Y ANDROID
             ========================================================= -->
        <ScrollView
            x:Name="LoginScrollView"
            Grid.Column="1">
            <Grid
                x:Name="ResponsiveRootGrid"
                Padding="{OnPlatform WinUI='44,32', Default='16,10'}"
                MinimumHeightRequest="{OnPlatform WinUI=650, Default=0}">

                <VerticalStackLayout
                    x:Name="LoginContentStack"
                    MaximumWidthRequest="500"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    Spacing="18">

                    <!-- Encabezado exclusivo para móvil -->
                    <VerticalStackLayout
                        x:Name="MobileHeader"
                        IsVisible="{OnPlatform WinUI=False, Default=True}"
                        HorizontalOptions="Center"
                        Spacing="4"
                        Margin="0,0,0,2">

                        <Border
                            x:Name="MobileLogoBorder"
                            WidthRequest="64"
                            HeightRequest="64"
                            Padding="4"
                            BackgroundColor="White"
                            Stroke="#DCE7E2"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 24">

                            <Border.Shadow>
                                <Shadow
                                    Brush="#1F352F"
                                    Offset="0,5"
                                    Radius="14"
                                    Opacity="0.14" />
                            </Border.Shadow>

                            <Image
                                Source="logocontradec.png"
                                Aspect="AspectFit" />
                        </Border>

                        <Label
                            x:Name="MobileAppTitle"
                            Text="ConatraCafé Soil"
                            FontFamily="MontserratBold"
                            FontSize="22"
                            FontAttributes="Bold"
                            HorizontalTextAlignment="Center"
                            TextColor="{StaticResource color_Verde}" />

                        <Label
                            x:Name="MobileTagline"
                            Text="CONATRADEC · Tecnología al servicio del café"
                            MaximumWidthRequest="340"
                            FontFamily="MontserratMedium"
                            FontSize="10"
                            HorizontalTextAlignment="Center"
                            LineBreakMode="WordWrap"
                            TextColor="#60736B" />
                    </VerticalStackLayout>

                    <!-- Tarjeta del login -->
                    <Border
                        x:Name="LoginCard"
                        Padding="{OnPlatform WinUI='34,30', Default='18,16'}"
                        BackgroundColor="White"
                        Stroke="#DCE5E1"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 26">

                        <Border.Shadow>
                            <Shadow
                                Brush="#233D36"
                                Offset="0,8"
                                Radius="24"
                                Opacity="0.13" />
                        </Border.Shadow>

                        <VerticalStackLayout
                            x:Name="LoginCardContent"
                            Spacing="12">

                            <!-- Encabezado y mascota interactiva -->
                            <Grid
                                x:Name="LoginHeaderGrid"
                                ColumnDefinitions="*,Auto"
                                ColumnSpacing="6">

                                <VerticalStackLayout
                                    x:Name="WelcomeTextStack"
                                    Grid.Column="0"
                                    VerticalOptions="Center"
                                    Spacing="3">

                                    <Label
                                        x:Name="WelcomeTitle"
                                        Text="Bienvenido"
                                        FontFamily="MontserratBold"
                                        FontSize="{OnPlatform WinUI=30, Default=25}"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource color_Negro}" />

                                    <Label
                                        x:Name="WelcomeSubtitle"
                                        Text="Ingresa tus credenciales para continuar."
                                        MaximumWidthRequest="285"
                                        FontFamily="MontserratMedium"
                                        FontSize="12"
                                        LineBreakMode="WordWrap"
                                        TextColor="{StaticResource color_GrisOscuro}" />
                                </VerticalStackLayout>

                                <!-- Escenario de la mascota -->
                                <Grid
                                    x:Name="MascotStage"
                                    Grid.Column="1"
                                    WidthRequest="{OnPlatform WinUI=150, Default=110}"
                                    HeightRequest="{OnPlatform WinUI=138, Default=100}"
                                    HorizontalOptions="End"
                                    VerticalOptions="Center">

                                    <!-- Partículas de celebración -->
                                    <Border
                                        x:Name="Confetti1"
                                        WidthRequest="7"
                                        HeightRequest="13"
                                        HorizontalOptions="Start"
                                        VerticalOptions="Start"
                                        BackgroundColor="#F2C94C"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 4"
                                        Opacity="0" />

                                    <Border
                                        x:Name="Confetti2"
                                        WidthRequest="7"
                                        HeightRequest="13"
                                        HorizontalOptions="End"
                                        VerticalOptions="Start"
                                        BackgroundColor="#E33E32"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 4"
                                        Opacity="0" />

                                    <Border
                                        x:Name="Confetti3"
                                        WidthRequest="8"
                                        HeightRequest="8"
                                        HorizontalOptions="Start"
                                        VerticalOptions="Center"
                                        BackgroundColor="#3B655B"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 8"
                                        Opacity="0" />

                                    <Border
                                        x:Name="Confetti4"
                                        WidthRequest="8"
                                        HeightRequest="8"
                                        HorizontalOptions="End"
                                        VerticalOptions="Center"
                                        BackgroundColor="#FF9800"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 8"
                                        Opacity="0" />

                                    <Border
                                        x:Name="Confetti5"
                                        WidthRequest="7"
                                        HeightRequest="12"
                                        HorizontalOptions="Start"
                                        VerticalOptions="End"
                                        BackgroundColor="#5EA8E5"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 4"
                                        Opacity="0" />

                                    <Border
                                        x:Name="Confetti6"
                                        WidthRequest="7"
                                        HeightRequest="12"
                                        HorizontalOptions="End"
                                        VerticalOptions="End"
                                        BackgroundColor="#7AB648"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 4"
                                        Opacity="0" />

                                    <!-- Halo -->
                                    <Border
                                        x:Name="MascotGlow"
                                        WidthRequest="{OnPlatform WinUI=108, Default=82}"
                                        HeightRequest="{OnPlatform WinUI=96, Default=75}"
                                        HorizontalOptions="Center"
                                        VerticalOptions="End"
                                        Margin="0,0,0,2"
                                        BackgroundColor="#F2C94C22"
                                        Stroke="#F2C94C55"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 38">

                                        <Border.Shadow>
                                            <Shadow
                                                Brush="#F2C94C"
                                                Offset="0,0"
                                                Radius="22"
                                                Opacity="0.18" />
                                        </Border.Shadow>
                                    </Border>

                                    <!-- Globo -->
                                    <Border
                                        x:Name="MascotSpeechBubble"
                                        Padding="9,5"
                                        HorizontalOptions="Start"
                                        VerticalOptions="Start"
                                        BackgroundColor="#FFF8D9"
                                        Stroke="#F2C94C"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 15"
                                        ZIndex="10">

                                        <Label
                                            x:Name="MascotSpeechText"
                                            Text="¡Bienvenido!"
                                            MaximumWidthRequest="{OnPlatform WinUI=126, Default=92}"
                                            FontFamily="MontserratMedium"
                                            FontSize="{OnPlatform WinUI=10, Default=8.5}"
                                            LineBreakMode="WordWrap"
                                            HorizontalTextAlignment="Center"
                                            TextColor="{StaticResource color_Verde}" />
                                    </Border>

                                    <!-- Parte que se mueve -->
                                    <Grid
                                        x:Name="MascotVisual"
                                        WidthRequest="{OnPlatform WinUI=112, Default=86}"
                                        HeightRequest="{OnPlatform WinUI=112, Default=86}"
                                        HorizontalOptions="Center"
                                        VerticalOptions="End"
                                        ZIndex="5">

                                        <Image
                                            x:Name="MascotImage"
                                            Source="mascota_cafe_conatradec.png"
                                            WidthRequest="{OnPlatform WinUI=108, Default=82}"
                                            HeightRequest="{OnPlatform WinUI=108, Default=82}"
                                            HorizontalOptions="Center"
                                            VerticalOptions="Center"
                                            BackgroundColor="Transparent"
                                            Aspect="AspectFit"
                                            SemanticProperties.Description="Mascota de café de CONATRADEC">

                                            <Image.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="MascotTapped" />
                                            </Image.GestureRecognizers>
                                        </Image>

                                        <!-- Antifaz de privacidad:
                                             aparece al escribir la contraseña -->
                                        <Border
                                            x:Name="PrivacyShield"
                                            WidthRequest="{OnPlatform WinUI=76, Default=58}"
                                            HeightRequest="{OnPlatform WinUI=27, Default=22}"
                                            Margin="{OnPlatform WinUI='0,27,0,0', Default='0,20,0,0'}"
                                            HorizontalOptions="Center"
                                            VerticalOptions="Start"
                                            BackgroundColor="#2D554A"
                                            Stroke="#F2C94C"
                                            StrokeThickness="1"
                                            StrokeShape="RoundRectangle 13"
                                            Opacity="0"
                                            Scale="0.65"
                                            TranslationX="35"
                                            ZIndex="15">

                                            <Label
                                                x:Name="PrivacyShieldText"
                                                Text="🔒  PRIVADO"
                                                HorizontalOptions="Center"
                                                VerticalOptions="Center"
                                                FontFamily="MontserratBold"
                                                FontSize="{OnPlatform WinUI=8, Default=7}"
                                                FontAttributes="Bold"
                                                TextColor="White" />
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Grid>

                            <!-- Usuario -->
                            <VerticalStackLayout
                                x:Name="UserFieldStack"
                                Spacing="5">
                                <Label
                                    Text="Correo electrónico"
                                    FontFamily="MontserratMedium"
                                    FontSize="13"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource color_Negro}" />

                                <Border
                                    x:Name="UserBorder"
                                    Padding="14,3"
                                    BackgroundColor="#F8FAF9"
                                    Stroke="#D6E1DC"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 14">

                                    <Entry
                                        x:Name="UserNameEntry"
                                        Text="{Binding Username}"
                                        Completed="UserNameEntryCompleted"
                                        Focused="UserNameEntry_Focused"
                                        Unfocused="InputEntry_Unfocused"
                                        TextChanged="UserNameEntry_TextChanged"
                                        Placeholder="nombre@correo.com"
                                        PlaceholderColor="#8B9691"
                                        Keyboard="Email"
                                        ReturnType="Next"
                                        FontFamily="MontserratMedium"
                                        FontSize="15"
                                        TextColor="{StaticResource color_Negro}"
                                        BackgroundColor="Transparent" />
                                </Border>
                            </VerticalStackLayout>

                            <!-- Contraseña -->
                            <VerticalStackLayout
                                x:Name="PasswordFieldStack"
                                IsVisible="{Binding LoginButtonVisible}"
                                Spacing="5">

                                <Label
                                    Text="Contraseña"
                                    FontFamily="MontserratMedium"
                                    FontSize="13"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource color_Negro}" />

                                <Border
                                    x:Name="PasswordBorder"
                                    Padding="14,3,8,3"
                                    BackgroundColor="#F8FAF9"
                                    Stroke="#D6E1DC"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 14">

                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <Entry
                                            x:Name="PasswordEntry"
                                            Grid.Column="0"
                                            Text="{Binding Password}"
                                            Completed="PasswordEntryCompleted"
                                            Focused="PasswordEntry_Focused"
                                            Unfocused="InputEntry_Unfocused"
                                            TextChanged="PasswordEntry_TextChanged"
                                            Placeholder="Ingresa tu contraseña"
                                            PlaceholderColor="#8B9691"
                                            IsPassword="{Binding IsPasswordHidden}"
                                            ReturnType="Go"
                                            FontFamily="MontserratMedium"
                                            FontSize="15"
                                            TextColor="{StaticResource color_Negro}"
                                            BackgroundColor="Transparent" />

                                        <ImageButton
                                            x:Name="PasswordToggleButton"
                                            Grid.Column="1"
                                            Source="{Binding PasswordToggleIcon}"
                                            Clicked="PasswordToggleButton_Clicked"
                                            WidthRequest="38"
                                            HeightRequest="38"
                                            Padding="8"
                                            BackgroundColor="Transparent"
                                            SemanticProperties.Description="Mostrar u ocultar contraseña" />
                                    </Grid>
                                </Border>
                            </VerticalStackLayout>

                            <!-- Recordarme -->
                            <Grid
                                x:Name="RememberMeGrid"
                                ColumnDefinitions="Auto,*"
                                ColumnSpacing="6">
                                <CheckBox
                                    Grid.Column="0"
                                    IsChecked="{Binding RememberMe}"
                                    Color="{StaticResource color_Verde}"
                                    VerticalOptions="Center" />

                                <VerticalStackLayout
                                    Grid.Column="1"
                                    VerticalOptions="Center"
                                    Spacing="1">

                                    <Label
                                        Text="Recordarme"
                                        FontFamily="MontserratMedium"
                                        FontSize="14"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource color_Negro}" />

                                    <Label
                                        Text="Mantiene tus credenciales guardadas en este dispositivo."
                                        FontSize="11"
                                        LineBreakMode="WordWrap"
                                        TextColor="{StaticResource color_GrisOscuro}" />
                                </VerticalStackLayout>
                            </Grid>

                            <!-- Biométrico -->
                            <Border
                                x:Name="BiometricBorder"
                                IsVisible="{Binding CanUseBiometrics}"
                                Padding="10"
                                BackgroundColor="#F1F7F4"
                                Stroke="#CFE0D9"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 14">

                                <Grid RowDefinitions="Auto,Auto" RowSpacing="4">
                                    <Grid
                                        Grid.Row="0"
                                        ColumnDefinitions="*,Auto"
                                        ColumnSpacing="12">

                                        <VerticalStackLayout
                                            Grid.Column="0"
                                            VerticalOptions="Center"
                                            Spacing="2">

                                            <Label
                                                Text="Acceso biométrico"
                                                FontFamily="MontserratMedium"
                                                FontSize="14"
                                                FontAttributes="Bold"
                                                TextColor="{StaticResource color_Verde}" />

                                            <Label
                                                Text="Usar huella o reconocimiento facial."
                                                FontSize="11"
                                                TextColor="{StaticResource color_GrisOscuro}" />
                                        </VerticalStackLayout>

                                        <Switch
                                            Grid.Column="1"
                                            IsToggled="{Binding UseBiometrics}"
                                            IsEnabled="{Binding CanToggleBiometrics}"
                                            Style="{StaticResource SwitchStyle}"
                                            VerticalOptions="Center" />
                                    </Grid>

                                    <Label
                                        Grid.Row="1"
                                        Text="Activa primero la opción «Recordarme»."
                                        IsVisible="{Binding TitleBiometric}"
                                        Margin="0,3,0,0"
                                        FontSize="11"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource color_Cafe}" />
                                </Grid>
                            </Border>

                            <ActivityIndicator
                                x:Name="BusyIndicator"
                                IsRunning="{Binding IsBusy}"
                                IsVisible="{Binding IsBusy}"
                                Color="{StaticResource color_Naranja}"
                                HeightRequest="30" />

                            <!-- Login tradicional -->
                            <Button
                                x:Name="LoginButton"
                                Text="Iniciar sesión"
                                Command="{Binding LoginCommand}"
                                Clicked="LoginButton_Clicked"
                                IsVisible="{Binding LoginButtonVisible}"
                                IsEnabled="{Binding NotIsBusy}"
                                HeightRequest="54"
                                Padding="18,12"
                                CornerRadius="14"
                                BackgroundColor="{StaticResource color_Verde}"
                                TextColor="White"
                                FontFamily="MontserratBold"
                                FontSize="16"
                                FontAttributes="Bold"
                                SemanticProperties.Hint="Inicia sesión con el correo y la contraseña ingresados" />

                            <!-- Login biométrico -->
                            <VerticalStackLayout
                                IsVisible="{Binding BiometricEnabled}"
                                HorizontalOptions="Center"
                                Spacing="8">

                                <ImageButton
                                    x:Name="BiometricButton"
                                    Source="fingerprint.png"
                                    Command="{Binding BiometricLoginCommand}"
                                    Clicked="BiometricButton_Clicked"
                                    WidthRequest="76"
                                    HeightRequest="76"
                                    Padding="8"
                                    CornerRadius="38"
                                    BackgroundColor="#EAF3EF"
                                    BorderColor="#C6DCD3"
                                    BorderWidth="1"
                                    SemanticProperties.Description="Autenticar con biometría" />

                                <Label
                                    Text="Toca para autenticar con huella o Face ID"
                                    FontFamily="MontserratMedium"
                                    FontSize="12"
                                    HorizontalTextAlignment="Center"
                                    TextColor="{StaticResource color_GrisOscuro}" />
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <Label
                        x:Name="MobileFooter"
                        Text="CONATRADEC · Tecnología al servicio del café"
                        HorizontalOptions="Center"
                        HorizontalTextAlignment="Center"
                        FontFamily="MontserratMedium"
                        FontSize="11"
                        TextColor="{StaticResource color_GrisOscuro}" />
                </VerticalStackLayout>
            </Grid>
        </ScrollView>
    </Grid>
</ContentPage>
